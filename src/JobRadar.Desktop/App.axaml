<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="JobRadar.Desktop.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <sty:FluentAvaloniaTheme CustomAccentColor="#7C5CFF" PreferSystemTheme="False"/>
        <StyleInclude Source="avares://JobRadar.Desktop/Themes/Controls.axaml"/>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://JobRadar.Desktop/Themes/Tokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
