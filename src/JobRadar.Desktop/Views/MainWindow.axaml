<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JobRadar.Desktop.ViewModels"
        xmlns:ctl="using:JobRadar.Desktop.Controls"
        xmlns:core="using:JobRadar"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
        xmlns:l="using:JobRadar.Desktop.Localization"
        x:Class="JobRadar.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1080" Height="700" MinWidth="840" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/radar.ico"
        Background="{DynamicResource Bg}"
        Foreground="{DynamicResource Text}"
        Title="Job Radar">

    <Window.Styles>
        <!-- Sidebar nav buttons -->
        <Style Selector="Button.nav">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13.5"/>
        </Style>
        <Style Selector="Button.nav /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.13"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.13"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Panel2}"/>
            <Setter Property="Foreground" Value="{DynamicResource Text}"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
        </Style>
        <Style Selector="Button.nav.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
        </Style>

        <!-- Coach chat bubbles: assistant left on Panel2, user right on AccentSoft.
             Alignment/colour flip via the "user" class — no converters needed. -->
        <Style Selector="Border.bubble">
            <Setter Property="Background" Value="{DynamicResource Panel2}"/>
            <Setter Property="CornerRadius" Value="12,12,12,4"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,0,60,8"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="620"/>
        </Style>
        <Style Selector="Border.bubble.user">
            <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
            <Setter Property="CornerRadius" Value="12,12,4,12"/>
            <Setter Property="Margin" Value="60,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- Brief accent flash used to draw the eye to a setting jumped to from elsewhere -->
        <Style Selector="Border.flash">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.45"/>
                    <BrushTransition Property="Background" Duration="0:0:0.45"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.flash.on">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
        </Style>
    </Window.Styles>

    <LayoutTransformControl>
      <LayoutTransformControl.LayoutTransform>
        <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
      </LayoutTransformControl.LayoutTransform>
    <Grid ColumnDefinitions="244,*">

        <!-- ================= SIDEBAR ================= -->
        <Border Grid.Column="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="16,22,16,18">

                <!-- Brand -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="11" Margin="6,0,0,22">
                    <Grid Width="34" Height="34" VerticalAlignment="Center">
                        <Ellipse Width="34" Height="34" Stroke="{DynamicResource Accent}" StrokeThickness="1.5" Opacity="0.5"/>
                        <Ellipse Width="20" Height="20" Stroke="{DynamicResource Accent}" StrokeThickness="1.5" Opacity="0.7"/>
                        <Ellipse Width="7"  Height="7"  Fill="{DynamicResource Accent}"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="Job Radar" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Text}"/>
                        <TextBlock Text="career signal" FontSize="10" Foreground="{DynamicResource Muted}"
                                   FontFamily="{DynamicResource MonoFont}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Spacing="4">
                    <Button Classes="nav" Classes.active="{Binding IsNavHome}" Command="{Binding NavigateCommand}" CommandParameter="home">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Home"/><TextBlock Text="{l:T nav.home}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavProfile}" Command="{Binding NavigateCommand}" CommandParameter="profile">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Contact"/><TextBlock Text="{l:T nav.profile}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavResults}" Command="{Binding NavigateCommand}" CommandParameter="results">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Find"/><TextBlock Text="{l:T nav.jobs}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavResearcher}" Command="{Binding NavigateCommand}" CommandParameter="researcher">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="People"/><TextBlock Text="{l:T nav.researcher}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavImprove}" Command="{Binding NavigateCommand}" CommandParameter="improve">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Flag"/><TextBlock Text="{l:T nav.improve}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavCoach}" Command="{Binding NavigateCommand}" CommandParameter="coach">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Comment"/><TextBlock Text="{l:T nav.coach}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavCv}" Command="{Binding NavigateCommand}" CommandParameter="cv">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Document"/><TextBlock Text="{l:T nav.cv}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsNavSettings}" Command="{Binding NavigateCommand}" CommandParameter="settings">
                        <StackPanel Orientation="Horizontal" Spacing="11"><ui:SymbolIcon Symbol="Settings"/><TextBlock Text="{l:T nav.settings}" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>

                <!-- Theme toggle -->
                <Button Grid.Row="2" Classes="nav" Command="{Binding ToggleThemeCommand}" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="11">
                        <ui:SymbolIcon Symbol="DarkTheme"/>
                        <TextBlock VerticalAlignment="Center" Text="{Binding ThemeToggleLabel}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ================= CONTENT ================= -->
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
          <Border MaxWidth="860" HorizontalAlignment="Left" Margin="44,36,44,52">
            <Grid>

                <!-- ============ HOME ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsWelcome}" Spacing="0" HorizontalAlignment="Center" MaxWidth="600" Margin="0,36,0,0">
                    <ctl:HeroMark HorizontalAlignment="Center"/>
                    <TextBlock Text="Job Radar" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center"
                               Margin="0,18,0,0" Foreground="{DynamicResource Text}"/>
                    <TextBlock Classes="sub" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="470" Margin="0,9,0,0" FontSize="14"
                               Text="{l:T home.tagline}"/>

                    <!-- Returning user -->
                    <Border Classes="card" Margin="0,28,0,0" IsVisible="{Binding HasSavedProfile}">
                        <StackPanel Spacing="14" HorizontalAlignment="Center">
                            <Border Classes="chip" Padding="12,7" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <ui:SymbolIcon Symbol="Contact" Foreground="{DynamicResource AccentText}"/>
                                    <TextBlock Text="{Binding SavedProfileLabel}" Foreground="{DynamicResource AccentText}"
                                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <Button Classes="accent" Command="{Binding StartSearchCommand}" IsEnabled="{Binding !Busy}" ToolTip.Tip="{l:T home.search.tip}">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Find"/><TextBlock Text="{l:T home.search}"/></StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding ViewJobsCommand}" IsEnabled="{Binding !Busy}" ToolTip.Tip="{l:T home.viewJobs.tip}">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="List"/><TextBlock Text="{l:T home.viewJobs}"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <Button Classes="ghost" Command="{Binding EditProfileCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Edit"/><TextBlock Text="{l:T home.editProfile}"/></StackPanel>
                                </Button>
                                <Button Classes="link" Click="OnPickCv" IsEnabled="{Binding !Busy}" Content="{l:T home.loadOtherCv}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- First time -->
                    <Border Classes="card" Margin="0,28,0,0" IsVisible="{Binding !HasSavedProfile}">
                        <StackPanel Spacing="13" HorizontalAlignment="Center">
                            <TextBlock Text="{l:T home.firstTitle}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Foreground="{DynamicResource Text}"/>
                            <TextBlock Classes="sub" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="380"
                                       Text="{l:T home.firstSub}"/>
                            <Button Classes="accent" HorizontalAlignment="Center" Click="OnPickCv" IsEnabled="{Binding !Busy}">
                                <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="OpenFile"/><TextBlock Text="{l:T home.pickCv}"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Classes="sub" Text="{Binding Status}" HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,12,0,0"
                               IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Classes="ghost" Command="{Binding LoadDemoCvCommand}" IsEnabled="{Binding !Busy}" ToolTip.Tip="{l:T home.demoCv.tip}">
                            <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Document"/><TextBlock Text="{l:T home.demoCv}"/></StackPanel>
                        </Button>
                        <Button Classes="ghost" Command="{Binding RunDemoCommand}" IsEnabled="{Binding !Busy}">
                            <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Play"/><TextBlock Text="{l:T home.demoRun}"/></StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Background="{DynamicResource AccentSoft}" CornerRadius="10" Padding="13" Margin="0,18,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Text}" TextAlignment="Center"
                                   Text="{l:T home.privacy}"/>
                    </Border>
                </StackPanel>

                <!-- ============ PROFILE ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsProfile}" Spacing="6">
                    <TextBlock Classes="h1" Text="{l:T profile.title}"/>
                    <TextBlock Classes="sub" Text="{l:T profile.sub}"/>
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,24,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="fld" Text="{l:T profile.name}"/>
                                    <TextBox Text="{Binding Name}"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.field}"/>
                                    <TextBox Text="{Binding FieldText}" Watermark="{l:T profile.field.wm}"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.titles}"/>
                                    <TextBox Text="{Binding JobTitlesText}" Watermark="{l:T profile.titles.wm}"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.coreSkills}"/>
                                    <TextBox Text="{Binding CoreSkillsText}" Watermark="C#, .NET, Go"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.otherSkills}"/>
                                    <TextBox Text="{Binding SkillsText}"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.locations}"/>
                                    <TextBox Text="{Binding LocText}" Watermark="Porto, Portugal"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Classes="fld" Text="{l:T profile.years}"/>
                                    <TextBox Text="{Binding YearsText}"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.seniority}"/>
                                    <ComboBox ItemsSource="{Binding SeniorityOptions}" SelectedItem="{Binding Seniority}" HorizontalAlignment="Stretch"/>
                                    <TextBlock Classes="fld" Text="{l:T profile.salary}"/>
                                    <Grid ColumnDefinitions="*,10,*">
                                        <TextBox Grid.Column="0" Text="{Binding SalaryFloorText}" Watermark="{l:T profile.salary.min}"/>
                                        <TextBox Grid.Column="2" Text="{Binding SalaryTargetText}" Watermark="{l:T profile.salary.target}"/>
                                    </Grid>
                                    <TextBlock Classes="fld" Text="{l:T profile.workmode}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                        <CheckBox Content="{l:T profile.remote}" IsChecked="{Binding Remote}"/>
                                        <CheckBox Content="{l:T profile.hybrid}" IsChecked="{Binding Hybrid}"/>
                                        <CheckBox Content="{l:T profile.onsite}" IsChecked="{Binding Onsite}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <TextBlock Classes="fld" Text="{l:T profile.summary}"/>
                            <TextBox Text="{Binding Summary}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,16,0,0" VerticalAlignment="Center">
                                <TextBlock Classes="fld" Text="{l:T profile.classification}" Margin="0" VerticalAlignment="Center"/>
                                <ToggleSwitch IsChecked="{Binding UseAi}" OnContent="IA" OffContent="Keywords"/>
                                <TextBlock Classes="sub" VerticalAlignment="Center" TextWrapping="Wrap"
                                           Text="{l:T profile.classHint}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,18,0,0">
                                <Button Classes="accent" Command="{Binding StartSearchCommand}" IsEnabled="{Binding !Busy}">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Find"/><TextBlock Text="{l:T home.search}"/></StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding ExportCvCommand}" IsEnabled="{Binding !Busy}" ToolTip.Tip="{l:T profile.genCv.tip}">
                                    <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T profile.genCv}"/></StackPanel>
                                </Button>
                                <Button Classes="ghost" Content="{l:T profile.reset}" Command="{Binding ResetCommand}"/>
                            </StackPanel>
                            <TextBlock Classes="sub" Text="{Binding Status}" TextWrapping="Wrap" Margin="0,12,0,0"
                                       IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============ RESULTS ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsResults}" Spacing="10">
                    <TextBlock Classes="h1" Text="{Binding ResultsTitle}"/>

                    <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Border Classes="chip" Padding="9,5" Margin="0,0,10,8" VerticalAlignment="Center">
                            <TextBlock FontSize="12" FontFamily="{DynamicResource MonoFont}"><Run Text="{Binding Jobs.Count}" FontWeight="Bold"/><Run Text="{l:T results.of}"/><Run Text="{Binding TotalCount}"/></TextBlock>
                        </Border>
                        <TextBox Width="220" Margin="0,0,10,8" Watermark="{l:T results.search.wm}" Text="{Binding SearchText}">
                            <TextBox.InnerLeftContent><ui:SymbolIcon Symbol="Find" Margin="8,0,0,0" Foreground="{DynamicResource Muted}"/></TextBox.InnerLeftContent>
                        </TextBox>
                        <Button Classes="ghost" Command="{Binding AddFilterCommand}" Margin="0,0,10,8" ToolTip.Tip="{l:T results.filter.tip}">
                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Add"/><TextBlock Text="{l:T results.filter}"/></StackPanel>
                        </Button>
                        <TextBlock Classes="sub" VerticalAlignment="Center" Text="{l:T results.minScore}" Margin="0,0,8,8"/>
                        <ComboBox ItemsSource="{Binding MinScoreOptions}" SelectedItem="{Binding MinScore}" Width="84" Margin="0,0,10,8"/>
                        <Button Classes="ghost" Command="{Binding RescoreCommand}" IsEnabled="{Binding !Busy}" Margin="0,0,8,8" ToolTip.Tip="{l:T results.rescore.tip}">
                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Refresh"/><TextBlock Text="{l:T results.rescore}"/></StackPanel>
                        </Button>
                        <Button Classes="ghost" Command="{Binding ExportCommand}" IsEnabled="{Binding !Busy}" Margin="0,0,8,8">
                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T results.export}"/></StackPanel>
                        </Button>
                        <Button Classes="ghost" Command="{Binding OpenLinkedInCommand}" Margin="0,0,8,8" ToolTip.Tip="{l:T results.linkedin.tip}">
                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="LinkedIn"/></StackPanel>
                        </Button>
                        <Button Classes="ghost" Command="{Binding ToggleLinkedInImportCommand}" Margin="0,0,8,8" ToolTip.Tip="{l:T linkedin.import.tip}">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <ui:SymbolIcon Symbol="Download"/><TextBlock Text="{l:T linkedin.import}"/>
                                <Border Classes="chip" VerticalAlignment="Center" IsVisible="{Binding HasLinkedInImported}">
                                    <TextBlock Text="{Binding LinkedInImportedCount}"/>
                                </Border>
                            </StackPanel>
                        </Button>
                        <Button Classes="ghost" Command="{Binding DeleteJobsCommand}" IsEnabled="{Binding !Busy}" IsVisible="{Binding HasJobs}"
                                Margin="0,0,8,8" Foreground="{DynamicResource Danger}" ToolTip.Tip="{l:T results.delete.tip}">
                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Delete"/><TextBlock Text="{l:T results.delete}"/></StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- LinkedIn import: paste + AI extract. Opt-in and deliberately over-explained — the flow can
                         sound scary, so the copy stresses that the USER does the opening/copying in their own
                         browser and the app automates nothing against their account. -->
                    <Border Classes="card" IsVisible="{Binding ShowLinkedInImport}" Margin="0,2,0,4">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="{l:T linkedin.import.title}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                            </StackPanel>
                            <TextBlock Classes="sub" TextWrapping="Wrap" Text="{l:T linkedin.import.safe}"/>

                            <Grid ColumnDefinitions="20,*" Margin="0,2,0,0">
                                <TextBlock Grid.Column="0" Text="1." FontWeight="Bold" Foreground="{DynamicResource AccentText}"/>
                                <StackPanel Grid.Column="1" Spacing="7">
                                    <TextBlock Classes="sub" TextWrapping="Wrap" Text="{l:T linkedin.import.step1}"/>
                                    <Button Classes="ghost" HorizontalAlignment="Left" Command="{Binding OpenLinkedInCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T linkedin.import.open}"/></StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="20,*">
                                <TextBlock Grid.Column="0" Text="2." FontWeight="Bold" Foreground="{DynamicResource AccentText}"/>
                                <TextBlock Grid.Column="1" Classes="sub" TextWrapping="Wrap" Text="{l:T linkedin.import.step2}"/>
                            </Grid>
                            <Grid ColumnDefinitions="20,*">
                                <TextBlock Grid.Column="0" Text="3." FontWeight="Bold" Foreground="{DynamicResource AccentText}"/>
                                <StackPanel Grid.Column="1" Spacing="7">
                                    <TextBox Text="{Binding LinkedInPaste}" AcceptsReturn="True" Height="140" TextWrapping="Wrap"
                                             Watermark="{l:T linkedin.import.watermark}" IsEnabled="{Binding !IsImportingLinkedIn}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Classes="accent" Command="{Binding ExtractLinkedInJobsCommand}" IsEnabled="{Binding !IsImportingLinkedIn}">
                                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Add"/><TextBlock Text="{l:T linkedin.import.extract}"/></StackPanel>
                                        </Button>
                                        <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18" VerticalAlignment="Center" IsVisible="{Binding IsImportingLinkedIn}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Classes="sub" TextWrapping="Wrap" Foreground="{DynamicResource AccentText}" Text="{Binding LinkedInImportStatus}"
                                       IsVisible="{Binding LinkedInImportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasLinkedInImported}">
                                <TextBlock Grid.Column="0" Classes="sub" TextWrapping="Wrap" VerticalAlignment="Center" Text="{l:T linkedin.import.next}"/>
                                <Button Grid.Column="1" Classes="link" Margin="8,0,0,0" Command="{Binding ClearLinkedInImportsCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"><ui:SymbolIcon Symbol="Delete" FontSize="13"/><TextBlock Text="{l:T linkedin.import.clear}"/></StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Classes="sub" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Text="{l:T linkedin.import.nourl}"/>
                        </StackPanel>
                    </Border>

                    <!-- Filter rows (added via "+ Filtro") -->
                    <ItemsControl x:Name="FiltersList" ItemsSource="{Binding Filters}" Margin="0,0,0,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:JobFilter">
                                <Grid ColumnDefinitions="150,8,128,8,*,8,Auto" Margin="0,0,0,6">
                                    <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" ItemsSource="{Binding FieldOptions}" SelectedIndex="{Binding FieldIndex}"/>
                                    <ComboBox Grid.Column="2" HorizontalAlignment="Stretch" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding ModeIndex}"/>
                                    <TextBox Grid.Column="4" Text="{Binding Value}" Watermark="C#"/>
                                    <Button Grid.Column="6" Classes="ghost" Padding="12,9"
                                            Command="{Binding ((vm:MainViewModel)DataContext).RemoveFilterCommand, ElementName=FiltersList}"
                                            CommandParameter="{Binding}" ToolTip.Tip="{l:T filter.remove.tip}">
                                        <ui:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="sub" Text="{Binding ExportMsg}" IsVisible="{Binding ExportMsg, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Scanning state: the radar (+ pause) -->
                    <Border IsVisible="{Binding IsScoring}" Classes="card" Padding="24" Margin="0,2,0,2">
                        <StackPanel HorizontalAlignment="Center" Spacing="14">
                            <ctl:RadarScope HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ScoringStatus}" Foreground="{DynamicResource AccentText}" FontFamily="{DynamicResource MonoFont}"
                                       FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <Button Classes="ghost" HorizontalAlignment="Center" Command="{Binding PauseScoringCommand}" IsVisible="{Binding CanPause}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Pause"/><TextBlock Text="{l:T scoring.pause}"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Paused: resume -->
                    <Border IsVisible="{Binding CanResume}" Classes="card" Margin="0,2,0,2" BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sub" TextWrapping="Wrap" Text="{l:T scoring.paused}"/>
                            <Button Classes="accent" HorizontalAlignment="Left" Command="{Binding ResumeScoringCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Play"/><TextBlock Text="{l:T scoring.resume}"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Persistent scoring error: ScoringStatus lives inside the scanning card, which hides when
                         the run ends — a failure needs a surface that survives it. -->
                    <Border Classes="banner danger" Margin="0,2,0,0"
                            IsVisible="{Binding ScoringError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Grid ColumnDefinitions="Auto,10,*,8,Auto">
                            <ui:SymbolIcon Grid.Column="0" Symbol="Important" Foreground="{DynamicResource Danger}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Text="{l:T scoring.error.title}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Danger}"/>
                                <TextBlock Text="{Binding ScoringError}" Classes="sub" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="4" Classes="link" VerticalAlignment="Top" Command="{Binding DismissScoringErrorCommand}" ToolTip.Tip="{l:T banner.dismiss.tip}">
                                <ui:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Empty (hidden while the first results stream in) -->
                    <ctl:EmptyState Margin="0,2,0,0" Title="{l:T empty.results.title}" Body="{Binding EmptyMessage}">
                        <ctl:EmptyState.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!HasJobs"/>
                                <Binding Path="!IsScoring"/>
                            </MultiBinding>
                        </ctl:EmptyState.IsVisible>
                        <ctl:EmptyState.ActionContent>
                            <Button Classes="accent" HorizontalAlignment="Center" Command="{Binding StartSearchCommand}" IsEnabled="{Binding !Busy}">
                                <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Find"/><TextBlock Text="{l:T home.search}"/></StackPanel>
                            </Button>
                        </ctl:EmptyState.ActionContent>
                    </ctl:EmptyState>

                    <Expander Margin="0,0,0,4" Header="{l:T results.howScore}" IsVisible="{Binding HasJobs}">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Muted}" Margin="4"
                                   Text="{l:T results.howScore.body}"/>
                    </Expander>

                    <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                               Foreground="{DynamicResource Muted}" Text="{l:T engine.localNote}"
                               IsVisible="{Binding UsingLocalEngine}"/>

                    <ItemsControl ItemsSource="{Binding Jobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:JobVm">
                                <Expander Classes="jobCard" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="Auto,16,*" HorizontalAlignment="Stretch" Margin="2,9,8,9">
                                            <ctl:ScoreDial Grid.Column="0" Score="{Binding Score}" Label="{Binding ScoreLabel}" VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="2" Spacing="3">
                                                <Button Classes="link" Command="{Binding OpenCommand}" ToolTip.Tip="{l:T job.openTip}">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                </Button>
                                                <WrapPanel>
                                                    <TextBlock Text="{Binding Company}" Foreground="{DynamicResource TextSoft}" FontWeight="SemiBold" FontSize="11.5" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding Location}" Foreground="{DynamicResource Muted}" FontSize="11.5" Margin="0,0,10,0"/>
                                                    <Border Classes="chip" Margin="0,0,8,0" IsVisible="{Binding HasRemote}">
                                                        <TextBlock Text="{Binding Remote}"/>
                                                    </Border>
                                                    <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="7,2" Margin="0,0,8,0" IsVisible="{Binding HasSalary}">
                                                        <TextBlock Text="{Binding Salary}" Foreground="{DynamicResource Signal}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Source}" Foreground="{DynamicResource Muted}" FontSize="10.5" FontFamily="{DynamicResource MonoFont}"/>
                                                </WrapPanel>
                                                <TextBlock Text="{Binding Verdict}" FontSize="12" Foreground="{DynamicResource Text}" Opacity="0.85" TextWrapping="Wrap" Margin="0,3,0,0" IsVisible="{Binding HasVerdict}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>

                                    <StackPanel Spacing="8" Margin="6,2,6,8">
                                        <TextBlock Text="{l:T job.why}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource AccentText}"/>
                                        <TextBlock Text="{Binding Reasons}" FontSize="12" Foreground="{DynamicResource Text}" Opacity="0.9" TextWrapping="Wrap" IsVisible="{Binding HasReasons}"/>
                                        <TextBlock Text="{Binding RedFlags}" FontSize="12" Foreground="{DynamicResource Amber}" TextWrapping="Wrap" IsVisible="{Binding HasRedFlags}"/>
                                        <Border Background="{DynamicResource Panel2}" CornerRadius="6" Padding="9" IsVisible="{Binding HasExplanation}">
                                            <TextBlock Text="{Binding Explanation}" FontFamily="{DynamicResource MonoFont}" FontSize="11" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="ghost" Command="{Binding OpenCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Open"/><TextBlock Text="{l:T job.openJob}"/></StackPanel>
                                            </Button>
                                            <Button Classes="ghost" Command="{Binding ResearchCommand}" ToolTip.Tip="{l:T job.research.tip}">
                                                <Panel>
                                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T job.research}"/>
                                                        <StackPanel.IsVisible><MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="!IsResearching"/><Binding Path="!HasBrief"/></MultiBinding></StackPanel.IsVisible>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T job.research.again}"/>
                                                        <StackPanel.IsVisible><MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="!IsResearching"/><Binding Path="HasBrief"/></MultiBinding></StackPanel.IsVisible>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding IsResearching}"><ui:SymbolIcon Symbol="Dismiss" FontSize="14" VerticalAlignment="Center"/><TextBlock Text="{l:T job.research.cancel}"/></StackPanel>
                                                </Panel>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="9" IsVisible="{Binding IsResearching}">
                                            <ui:ProgressRing IsIndeterminate="True" Width="15" Height="15" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ResearchStatus}" FontSize="12" FontFamily="{DynamicResource MonoFont}"
                                                       Foreground="{DynamicResource AccentText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ResearchError}" FontSize="12" Foreground="{DynamicResource Danger}" TextWrapping="Wrap"
                                                   IsVisible="{Binding ResearchError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                        <Border IsVisible="{Binding HasBrief}" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}"
                                                BorderThickness="1" CornerRadius="10" Padding="14">
                                            <StackPanel Spacing="9">
                                                <TextBlock Text="{Binding BriefAsOf}" FontSize="10.5" Foreground="{DynamicResource Muted}" IsVisible="{Binding HasBriefAsOf}"/>
                                                <!-- Reputação -->
                                                <StackPanel IsVisible="{Binding Brief.HasReputation}" Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}"/>
                                                        <TextBlock Text="{l:T brief.reputation}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Brief.Pros}" IsVisible="{Binding Brief.HasPros}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                                <TextBlock Grid.Column="0" Text="✓" FontWeight="Bold" Foreground="{DynamicResource Signal}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <ItemsControl ItemsSource="{Binding Brief.Cons}" IsVisible="{Binding Brief.HasCons}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                                <TextBlock Grid.Column="0" Text="✕" FontWeight="Bold" Foreground="{DynamicResource Danger}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <ItemsControl ItemsSource="{Binding Brief.Context}" IsVisible="{Binding Brief.HasContext}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                                <TextBlock Grid.Column="0" Text="○" Foreground="{DynamicResource Muted}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"/>
                                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="{Binding Brief.ReputationNote}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" IsVisible="{Binding Brief.HasReputationNote}"/>
                                                </StackPanel>

                                                <!-- divider with flair -->
                                                <Border Height="2" Margin="0,8,0,8" CornerRadius="1" IsVisible="{Binding Brief.HasSalary}">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                            <GradientStop Offset="0" Color="#7C5CFF"/><GradientStop Offset="1" Color="#007C5CFF"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <!-- Salário -->
                                                <StackPanel IsVisible="{Binding Brief.HasSalary}" Spacing="7">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Signal}"/>
                                                        <TextBlock Text="{l:T brief.salary}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Brief.SalaryFound}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}" IsVisible="{Binding Brief.HasSalaryFound}"/>
                                                    <Border IsVisible="{Binding Brief.HasSalaryExpectation}" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="8" Padding="12">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Text="{l:T brief.expectation}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource AccentText}"/>
                                                            <TextBlock Text="{Binding Brief.SalaryExpectation}" FontSize="18" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                            <TextBlock Text="{Binding Brief.SalaryRationale}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" IsVisible="{Binding Brief.HasSalaryRationale}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <TextBlock Text="{Binding Brief.BottomLine}" FontSize="12" FontStyle="Italic" Opacity="0.9" TextWrapping="Wrap" Margin="0,4,0,0" Foreground="{DynamicResource Text}" IsVisible="{Binding Brief.HasBottomLine}"/>

                                                <StackPanel IsVisible="{Binding Brief.HasSources}" Spacing="1" Margin="0,4,0,0">
                                                    <TextBlock Text="{l:T common.sources}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                                    <ItemsControl ItemsSource="{Binding Brief.Sources}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:SourceRef">
                                                            <Button Classes="link" Content="{Binding Label}" FontSize="11"
                                                                    Command="{Binding $parent[ItemsControl].((vm:JobVm)DataContext).OpenUrlCommand}" CommandParameter="{Binding Url}"/>
                                                        </DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <md:MarkdownScrollViewer Markdown="{Binding Brief.RawFallback}" MaxHeight="440" MarkdownStyleName="FluentAvalonia" IsVisible="{Binding Brief.HasFallback}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ============ COMPANY RESEARCHER ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsResearcher}" Spacing="6" MaxWidth="760">
                    <TextBlock Classes="h1" Text="{l:T nav.researcher}"/>
                    <TextBlock Classes="sub" Text="{l:T researcher.sub}"/>

                    <!-- Controls: research a specific company · sort · research all -->
                    <Border Classes="card" Margin="0,12,0,0" Padding="14,12">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Width="280" Watermark="{l:T researcher.manual.wm}" Text="{Binding CompanyQuery}"/>
                                <Button Classes="accent" Command="{Binding ResearchManualCompanyCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T researcher.manual.go}"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding HasCompanies}">
                                <TextBlock Text="{l:T researcher.sortBy}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource Muted}"/>
                                <ComboBox ItemsSource="{Binding CompanySorts}" SelectedIndex="{Binding CompanySortIndex}" MinWidth="150"/>
                                <Button Classes="ghost" Command="{Binding ResearchAllCompaniesCommand}" ToolTip.Tip="{l:T researcher.researchAll.tip}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T researcher.researchAll}"/></StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding ExportCompaniesCommand}" IsEnabled="{Binding !Busy}" ToolTip.Tip="{l:T researcher.export.tip}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T researcher.export}"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T researcher.byok}"/>
                            <TextBlock Classes="sub" Text="{Binding ExportMsg}" IsVisible="{Binding ExportMsg, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Filter the already-listed companies by name (shown only when there are companies) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,12,0,0" IsVisible="{Binding HasCompanies}">
                        <ui:SymbolIcon Symbol="Find" VerticalAlignment="Center" Foreground="{DynamicResource Muted}"/>
                        <TextBox Width="320" Watermark="{l:T researcher.filter.wm}" Text="{Binding CompanyFilter}"/>
                    </StackPanel>

                    <!-- Empty state: no matched jobs yet -->
                    <ctl:EmptyState Margin="0,12,0,0" Symbol="People" IsVisible="{Binding ResearcherEmpty}"
                                    Title="{l:T researcher.empty.title}" Body="{l:T researcher.empty.body}">
                        <ctl:EmptyState.ActionContent>
                            <Button Classes="accent" HorizontalAlignment="Center" Command="{Binding NavigateCommand}" CommandParameter="results">
                                <TextBlock Text="{l:T researcher.empty.cta}"/>
                            </Button>
                        </ctl:EmptyState.ActionContent>
                    </ctl:EmptyState>

                    <!-- Companies -->
                    <ItemsControl ItemsSource="{Binding Companies}" Margin="0,12,0,0" IsVisible="{Binding HasCompanies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CompanyVm">
                                <Expander Margin="0,0,0,8" HorizontalAlignment="Stretch" IsExpanded="{Binding Expanded}">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch" Margin="2,8,8,8">
                                            <StackPanel Grid.Column="0" Spacing="5">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                <WrapPanel>
                                                    <TextBlock Text="{Binding JobCountLabel}" Foreground="{DynamicResource Muted}" FontSize="11" Margin="0,0,10,2" VerticalAlignment="Center"/>
                                                    <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="7,2" Margin="0,0,6,2" IsVisible="{Binding HasRatingChip}">
                                                        <TextBlock Text="{Binding RatingChip}" Foreground="{DynamicResource Signal}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Border BorderBrush="{DynamicResource Amber}" BorderThickness="1" CornerRadius="7" Padding="7,1" Margin="0,0,6,2" IsVisible="{Binding HasLayoffChip}">
                                                        <TextBlock Text="{Binding LayoffChip}" Foreground="{DynamicResource Amber}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Border Classes="chip" Margin="0,0,6,2" IsVisible="{Binding HasPayChip}"><TextBlock Text="{Binding PayChip}"/></Border>
                                                    <Border Background="{DynamicResource Panel2}" CornerRadius="7" Padding="7,2" Margin="0,0,6,2" IsVisible="{Binding HasConfidenceChip}">
                                                        <TextBlock Text="{Binding ConfidenceChip}" Foreground="{DynamicResource Muted}" FontSize="10.5"/>
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="ghost" VerticalAlignment="Center" Command="{Binding ResearchCommand}" ToolTip.Tip="{l:T researcher.research.tip}">
                                                <Panel>
                                                    <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding !IsResearching}"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T researcher.research}"/></StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding IsResearching}"><ui:SymbolIcon Symbol="Dismiss" FontSize="14" VerticalAlignment="Center"/><TextBlock Text="{l:T job.research.cancel}"/></StackPanel>
                                                </Panel>
                                            </Button>
                                        </Grid>
                                    </Expander.Header>

                                    <StackPanel Spacing="9" Margin="6,2,6,8">
                                        <!-- live status / error -->
                                        <StackPanel Orientation="Horizontal" Spacing="9" IsVisible="{Binding IsResearching}">
                                            <ui:ProgressRing IsIndeterminate="True" Width="15" Height="15" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Status}" FontSize="12" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource AccentText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Error}" FontSize="12" Foreground="{DynamicResource Danger}" TextWrapping="Wrap" IsVisible="{Binding HasError}"/>

                                        <Border IsVisible="{Binding HasReport}" Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="10" Padding="14">
                                            <StackPanel Spacing="9">
                                                <!-- as of + best-effort caveat -->
                                                <TextBlock Text="{Binding AsOf}" FontSize="10.5" Foreground="{DynamicResource Muted}" IsVisible="{Binding HasAsOf}"/>

                                                <!-- thin-data honest note -->
                                                <TextBlock Text="{l:T researcher.thin}" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" IsVisible="{Binding Report.IsThin}"/>

                                                <!-- Satisfaction -->
                                                <StackPanel IsVisible="{Binding Report.HasSatisfaction}" Spacing="5">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Signal}"/>
                                                        <TextBlock Text="{l:T researcher.satisfaction}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                    </StackPanel>
                                                    <!-- aggregate star average -->
                                                    <StackPanel Orientation="Horizontal" Spacing="7" IsVisible="{Binding Report.HasRating}">
                                                        <TextBlock Text="★" FontSize="16" Foreground="{DynamicResource Signal}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Report.RatingText}" FontSize="16" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Report.ReviewsText}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" IsVisible="{Binding Report.HasReviewCount}"/>
                                                        <TextBlock Text="{l:T researcher.reviewsWord}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Margin="-3,0,0,0" IsVisible="{Binding Report.HasReviewCount}"/>
                                                        <TextBlock Text="{Binding Report.RatingSource}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Margin="2,0,0,0" IsVisible="{Binding Report.HasRatingSource}"/>
                                                    </StackPanel>
                                                    <!-- review count without an aggregate average -->
                                                    <WrapPanel IsVisible="{Binding Report.ShowReviewsOnly}">
                                                        <TextBlock Text="{Binding Report.ReviewsText}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{l:T researcher.reviewsWord}" FontSize="12" Foreground="{DynamicResource Muted}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Report.RatingSource}" FontSize="12" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" IsVisible="{Binding Report.HasRatingSource}"/>
                                                        <TextBlock Text="{l:T researcher.noAverage}" FontSize="11" FontStyle="Italic" Foreground="{DynamicResource Muted}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </WrapPanel>
                                                    <!-- recommend / CEO approval -->
                                                    <WrapPanel>
                                                        <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="8,3" Margin="0,0,6,2" IsVisible="{Binding Report.HasRecommend}">
                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <TextBlock Text="{Binding Report.RecommendText}" FontWeight="Bold" FontSize="11.5" Foreground="{DynamicResource Signal}"/>
                                                                <TextBlock Text="{l:T researcher.recommend}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource Signal}"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Background="{DynamicResource AccentSoft}" CornerRadius="7" Padding="8,3" Margin="0,0,6,2" IsVisible="{Binding Report.HasCeoApproval}">
                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <TextBlock Text="{Binding Report.CeoApprovalText}" FontWeight="Bold" FontSize="11.5" Foreground="{DynamicResource AccentText}"/>
                                                                <TextBlock Text="{l:T researcher.ceo}" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </WrapPanel>
                                                    <!-- sub-ratings (Glassdoor/Comparably) -->
                                                    <WrapPanel IsVisible="{Binding Report.HasSubRatings}">
                                                        <Border Classes="chip" Margin="0,0,6,3" IsVisible="{Binding Report.HasWorkLife}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.sub.worklife}"/><TextBlock Text="{Binding Report.WorkLifeText}" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Classes="chip" Margin="0,0,6,3" IsVisible="{Binding Report.HasCulture}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.sub.culture}"/><TextBlock Text="{Binding Report.CultureText}" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Classes="chip" Margin="0,0,6,3" IsVisible="{Binding Report.HasCareer}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.sub.career}"/><TextBlock Text="{Binding Report.CareerText}" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Classes="chip" Margin="0,0,6,3" IsVisible="{Binding Report.HasManagement}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.sub.management}"/><TextBlock Text="{Binding Report.ManagementText}" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Classes="chip" Margin="0,0,6,3" IsVisible="{Binding Report.HasCompensation}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.sub.comp}"/><TextBlock Text="{Binding Report.CompensationText}" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Classes="chip" Margin="0,0,6,3" IsVisible="{Binding Report.HasDiversity}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.sub.diversity}"/><TextBlock Text="{Binding Report.DiversityText}" FontWeight="Bold"/></StackPanel></Border>
                                                    </WrapPanel>
                                                    <WrapPanel>
                                                        <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="8,3" Margin="0,0,6,2" IsVisible="{Binding Report.HasENps}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="eNPS" FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource Signal}"/><TextBlock Text="{Binding Report.ENpsText}" FontWeight="Bold" FontSize="11.5" Foreground="{DynamicResource Signal}"/></StackPanel></Border>
                                                        <Border Classes="chip" Margin="0,0,6,2" IsVisible="{Binding Report.HasInterviewDifficulty}"><StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="{l:T researcher.interview}"/><TextBlock Text="{Binding Report.InterviewDifficulty}" FontWeight="SemiBold"/></StackPanel></Border>
                                                    </WrapPanel>
                                                </StackPanel>

                                                <!-- Layoffs -->
                                                <StackPanel IsVisible="{Binding Report.HasLayoffs}" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Amber}"/>
                                                        <TextBlock Text="{l:T researcher.layoffs}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Report.Layoffs}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:LayoffEvent">
                                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                                <TextBlock Grid.Column="0" Text="⚠" Foreground="{DynamicResource Amber}"/>
                                                                <StackPanel Grid.Column="1" Spacing="0">
                                                                    <TextBlock Text="{Binding Display}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                                    <Button Classes="link" Content="{Binding Url}" FontSize="10.5" IsVisible="{Binding HasUrl}"
                                                                            Command="{Binding $parent[ItemsControl].((vm:CompanyVm)DataContext).OpenUrlCommand}" CommandParameter="{Binding Url}"/>
                                                                </StackPanel>
                                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Recent signals -->
                                                <StackPanel IsVisible="{Binding Report.HasSignals}" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}"/>
                                                        <TextBlock Text="{l:T researcher.signals}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding Report.Signals}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                                <TextBlock Grid.Column="0" Text="•" Foreground="{DynamicResource AccentText}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Pay band -->
                                                <StackPanel IsVisible="{Binding Report.HasPayBand}" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}"/>
                                                        <TextBlock Text="{l:T researcher.pay}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Report.PayBand}" FontSize="15" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                    <TextBlock Text="{Binding Report.PayRole}" FontSize="11" Foreground="{DynamicResource Muted}" IsVisible="{Binding Report.HasPayRole}"/>
                                                </StackPanel>

                                                <!-- Tenure -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding Report.HasTenure}">
                                                    <TextBlock Text="{l:T researcher.tenure}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource Muted}"/>
                                                    <TextBlock Text="{Binding Report.Tenure}" FontSize="12" Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- About / firmographics (Wikidata-grounded) -->
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding Report.HasFirmographics}">
                                                    <TextBlock Text="{l:T researcher.about}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Top" Margin="0,1,0,0" Foreground="{DynamicResource Muted}"/>
                                                    <TextBlock Text="{Binding Report.Firmographics}" FontSize="12" Foreground="{DynamicResource Text}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding Report.HasCeo}">
                                                    <TextBlock Text="{l:T researcher.ceoName}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource Muted}"/>
                                                    <TextBlock Text="{Binding Report.Ceo}" FontSize="12" Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Classes="link" Content="{Binding Report.Website}" FontSize="11.5" HorizontalAlignment="Left" Padding="0" IsVisible="{Binding Report.HasWebsite}"
                                                        Command="{Binding OpenUrlCommand}" CommandParameter="{Binding Report.Website}"/>

                                                <!-- Tech stack seen in their own postings -->
                                                <StackPanel IsVisible="{Binding Report.HasTechStack}" Spacing="4">
                                                    <TextBlock Text="{l:T researcher.stack}" FontSize="11" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                                    <ItemsControl ItemsSource="{Binding Report.TechStack}">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                            <Border Classes="chip" Margin="0,0,6,4"><TextBlock Text="{Binding}"/></Border>
                                                        </DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Pros / Cons / Red flags -->
                                                <ItemsControl ItemsSource="{Binding Report.Pros}" IsVisible="{Binding Report.HasPros}">
                                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                        <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                            <TextBlock Grid.Column="0" Text="✓" FontWeight="Bold" Foreground="{DynamicResource Signal}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                        </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding Report.Cons}" IsVisible="{Binding Report.HasCons}">
                                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                        <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                            <TextBlock Grid.Column="0" Text="✕" FontWeight="Bold" Foreground="{DynamicResource Danger}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                        </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding Report.RedFlags}" IsVisible="{Binding Report.HasRedFlags}">
                                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                                        <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                            <TextBlock Grid.Column="0" Text="⚠" Foreground="{DynamicResource Amber}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Amber}"/>
                                                        </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding Report.BottomLine}" FontSize="12" FontStyle="Italic" Opacity="0.9" TextWrapping="Wrap" Margin="0,4,0,0" Foreground="{DynamicResource Text}" IsVisible="{Binding Report.HasBottomLine}"/>

                                                <!-- Sources -->
                                                <StackPanel IsVisible="{Binding Report.HasSources}" Spacing="1" Margin="0,4,0,0">
                                                    <TextBlock Text="{l:T common.sources}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                                    <ItemsControl ItemsSource="{Binding Report.Sources}">
                                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:SourceRef">
                                                            <Button Classes="link" Content="{Binding Label}" FontSize="11"
                                                                    Command="{Binding $parent[ItemsControl].((vm:CompanyVm)DataContext).OpenUrlCommand}" CommandParameter="{Binding Url}"/>
                                                        </DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <md:MarkdownScrollViewer Markdown="{Binding Report.RawFallback}" MaxHeight="440" MarkdownStyleName="FluentAvalonia" IsVisible="{Binding Report.HasFallback}"/>

                                                <TextBlock Text="{l:T researcher.disclaimer}" FontSize="10.5" FontStyle="Italic" TextWrapping="Wrap" Margin="0,4,0,0" Foreground="{DynamicResource Muted}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ============ IMPROVE (career plan) ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsImprove}" Spacing="6" MaxWidth="720">
                    <TextBlock Classes="h1" Text="{l:T nav.improve}"/>
                    <TextBlock Classes="sub" Text="{l:T improve.sub}"/>

                    <!-- Adversarial review: how hard the AI challenges its own plan after generating -->
                    <Border Classes="card" Margin="0,8,0,0" Padding="13,11">
                        <StackPanel Spacing="7">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Find" Foreground="{DynamicResource AccentText}" VerticalAlignment="Center"/>
                                <TextBlock Text="{l:T improve.critiqueMode}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource Text}"/>
                                <ComboBox ItemsSource="{Binding CritiqueModes}" SelectedIndex="{Binding CritiqueModeIndex}" MinWidth="170"/>
                            </StackPanel>
                            <TextBlock Classes="sub" FontSize="11.5" TextWrapping="Wrap" Text="{l:T improve.critiqueMode.why}"/>
                        </StackPanel>
                    </Border>

                    <!-- Generate (no plan yet) -->
                    <Border Classes="card" Margin="0,12,0,0" IsVisible="{Binding ShowGenerateIntro}">
                        <StackPanel Spacing="13">
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSoft}" FontSize="13"
                                       Text="{l:T improve.intro}"/>
                            <Button Classes="accent" HorizontalAlignment="Left" Command="{Binding GeneratePlanCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8"><ui:SymbolIcon Symbol="Flag"/><TextBlock Text="{l:T improve.generate}"/></StackPanel>
                            </Button>
                            <TextBlock Classes="sub" Text="{l:T improve.byok}"/>
                            <TextBlock Text="{Binding PlanError}" Foreground="{DynamicResource Danger}" FontSize="12" TextWrapping="Wrap"
                                       IsVisible="{Binding PlanError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <Button Classes="ghost" HorizontalAlignment="Left" IsVisible="{Binding PlanErrorIsTokenLimit}"
                                    Command="{Binding GoToTokenSettingCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Settings"/><TextBlock Text="{l:T plan.error.fixTokens}"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Researching: the radar + live model thinking -->
                    <Border IsVisible="{Binding IsPlanning}" Classes="card" Padding="24" Margin="0,12,0,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="14">
                            <ctl:RadarScope HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PlanStatus}" Foreground="{DynamicResource AccentText}" FontFamily="{DynamicResource MonoFont}"
                                       FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <Border IsVisible="{Binding HasPlanReasoning}" Background="{DynamicResource Panel2}" CornerRadius="8" Padding="12,10" MaxWidth="600">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="{l:T plan.thinking}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                    <TextBlock Text="{Binding PlanReasoningTail}" FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                               TextWrapping="Wrap" Foreground="{DynamicResource TextSoft}"/>
                                </StackPanel>
                            </Border>
                            <Button Classes="ghost" HorizontalAlignment="Center" Command="{Binding PausePlanCommand}" IsVisible="{Binding CanPausePlan}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Pause"/><TextBlock Text="{l:T plan.pause}"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Paused: resume reuses the research + completed parts -->
                    <Border IsVisible="{Binding CanResumePlan}" Classes="card" Padding="16" Margin="0,12,0,0">
                        <StackPanel Spacing="11" HorizontalAlignment="Center">
                            <TextBlock Text="{l:T plan.resumeHint}" FontSize="12.5" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextSoft}"/>
                            <Button Classes="accent" HorizontalAlignment="Center" Command="{Binding ResumePlanCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Play"/><TextBlock Text="{l:T plan.resume}"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Demand from your own scored jobs (Part B) -->
                    <Border IsVisible="{Binding HasDemand}" Classes="card" Margin="0,12,0,0" Padding="13,11">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="{l:T improve.demand.title}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                <TextBlock Text="{Binding DemandHeader}" FontSize="11.5" VerticalAlignment="Center" Foreground="{DynamicResource Muted}"/>
                            </StackPanel>
                            <TextBlock Text="{l:T improve.demand.caption}" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"/>
                            <TextBlock Text="{l:T improve.demand.thin}" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Amber}" IsVisible="{Binding DemandThin}"/>
                            <ItemsControl ItemsSource="{Binding PlanMarket.SkillDemand}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:SkillStat">
                                    <Border Classes="chip" Padding="9,4" Margin="0,4,7,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Skill}" FontSize="12" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Count}" FontSize="12" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource Muted}"/>
                                        </StackPanel>
                                    </Border></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Spacing="2" Margin="0,3,0,0" IsVisible="{Binding PlanMarket.HasRoleMatches}">
                                <TextBlock Text="{l:T improve.demand.roles}" FontSize="10.5" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                <ItemsControl ItemsSource="{Binding PlanMarket.RoleMatches}">
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:JobRef">
                                        <Button Classes="link" FontSize="11.5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenUrlCommand}" CommandParameter="{Binding Url}">
                                            <TextBlock TextWrapping="Wrap"><Run Text="{Binding Title}"/><Run Text=" · "/><Run Text="{Binding Company}" Foreground="{DynamicResource Muted}"/></TextBlock>
                                        </Button></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- The plan -->
                    <StackPanel IsVisible="{Binding HasPlan}" Spacing="12" Margin="0,12,0,0">
                        <!-- Positioning headline (full width) -->
                        <Border Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="10" Padding="14">
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{l:T improve.positioning}" FontSize="10" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                    <Border Background="{DynamicResource Signal}" CornerRadius="6" Padding="7,1" VerticalAlignment="Center" IsVisible="{Binding PlanRevised}">
                                        <TextBlock Text="{l:T improve.revised}" FontSize="9.5" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Plan.Headline}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                            </StackPanel>
                        </Border>

                        <!-- AI caveat — temper trust right under the headline -->
                        <TextBlock Text="{Binding PlanCaveat}" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"
                                   IsVisible="{Binding PlanCaveat, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="{l:T engine.localNote}" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"
                                   IsVisible="{Binding UsingLocalEngine}"/>

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="ghost" Command="{Binding ExportPlanCommand}" IsEnabled="{Binding !Busy}" ToolTip.Tip="{l:T plan.exportPdf.tip}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T plan.exportPdf}"/></StackPanel>
                            </Button>
                            <Button Classes="ghost" Command="{Binding GeneratePlanCommand}" ToolTip.Tip="{l:T improve.regenerate.tip}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Refresh"/><TextBlock Text="{l:T improve.regenerate}"/></StackPanel>
                            </Button>
                            <CheckBox IsChecked="{Binding IncludeProgressInPdf}" Content="{l:T plan.includeProgress}" VerticalAlignment="Center"
                                      IsVisible="{Binding HasPlanProgress}" ToolTip.Tip="{l:T plan.includeProgress.tip}"/>
                        </StackPanel>

                        <!-- Progresso: o plano como checklist que percorres -->
                        <Border IsVisible="{Binding HasPlanProgress}" Classes="card" Padding="13,10">
                            <StackPanel Spacing="7">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.progress}" FontSize="11" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource AccentText}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PlanProgressText}" FontSize="12.5" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding PlanProgressPercent}" Height="6"/>
                                <TextBlock Text="{l:T improve.progress.done}" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Foreground="{DynamicResource Signal}" IsVisible="{Binding PlanComplete}"/>
                            </StackPanel>
                        </Border>

                        <!-- O que mudou desde o plano anterior -->
                        <Border IsVisible="{Binding HasPlanChanges}" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Signal}" BorderThickness="1" CornerRadius="10" Padding="13,10">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Signal}"/>
                                    <TextBlock Text="{l:T improve.changed}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource Signal}"/>
                                    <TextBlock Text="{Binding PlanChanges.PrevDate}" FontSize="10.5" VerticalAlignment="Center" Foreground="{DynamicResource Muted}"/>
                                </StackPanel>
                                <Grid ColumnDefinitions="150,*" IsVisible="{Binding PlanChanges.HasGapsClosed}">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.changed.gapsClosed}" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Signal}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PlanChanges.GapsClosedText}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                </Grid>
                                <Grid ColumnDefinitions="150,*" IsVisible="{Binding PlanChanges.HasGapsNew}">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.changed.gapsNew}" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Amber}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PlanChanges.GapsNewText}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                </Grid>
                                <Grid ColumnDefinitions="150,*" IsVisible="{Binding PlanChanges.HasRolesAdded}">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.changed.rolesAdded}" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource AccentText}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PlanChanges.RolesAddedText}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                </Grid>
                                <Grid ColumnDefinitions="150,*" IsVisible="{Binding PlanChanges.HasRolesDropped}">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.changed.rolesDropped}" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Muted}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PlanChanges.RolesDroppedText}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"/>
                                </Grid>
                                <Grid ColumnDefinitions="150,*" IsVisible="{Binding PlanChanges.HasSalaryNowMove}">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.changed.salaryNow}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Top" Foreground="{DynamicResource AccentText}"/>
                                    <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,*">
                                        <TextBlock Grid.Column="0" Text="{Binding PlanChanges.SalaryNowBefore}" FontSize="11.5" Margin="0,0,6,0" VerticalAlignment="Top" Foreground="{DynamicResource Muted}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PlanChanges.SalaryNowArrow}" FontSize="11.5" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Top" Foreground="{DynamicResource AccentText}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding PlanChanges.SalaryNowAfter}" FontSize="11.5" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                    </Grid>
                                </Grid>
                                <Grid ColumnDefinitions="150,*" IsVisible="{Binding PlanChanges.HasSalaryPotentialMove}">
                                    <TextBlock Grid.Column="0" Text="{l:T improve.changed.salaryPotential}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Top" Foreground="{DynamicResource AccentText}"/>
                                    <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,*">
                                        <TextBlock Grid.Column="0" Text="{Binding PlanChanges.SalaryPotentialBefore}" FontSize="11.5" Margin="0,0,6,0" VerticalAlignment="Top" Foreground="{DynamicResource Muted}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PlanChanges.SalaryPotentialArrow}" FontSize="11.5" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Top" Foreground="{DynamicResource AccentText}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding PlanChanges.SalaryPotentialAfter}" FontSize="11.5" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Adversarial review still running (plan already visible) -->
                        <Border IsVisible="{Binding IsCritiquing}" Background="{DynamicResource AccentSoft}" CornerRadius="8" Padding="11,8">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PlanStatus}" FontSize="11.5" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource AccentText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="{Binding PlanReasoningTail}" FontFamily="{DynamicResource MonoFont}" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSoft}" IsVisible="{Binding HasPlanReasoning}"/>
                                <Button Classes="ghost" HorizontalAlignment="Left" Command="{Binding PausePlanCommand}" IsVisible="{Binding CanPausePlan}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Pause"/><TextBlock Text="{l:T plan.pause}"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Foco: se fizeres só uma coisa (Part C) -->
                        <Border IsVisible="{Binding HasFocusGap}" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="10" Padding="13,10">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{l:T improve.focus.hint}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource AccentText}"/>
                                <TextBlock Text="{Binding FocusGap.Skill}" FontSize="13.5" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                <TextBlock Text="{Binding FocusGap.CorpusLabel}" FontSize="11.5" Foreground="{DynamicResource Muted}" IsVisible="{Binding FocusGap.HasCorpusHits}"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <!-- Pontos fortes -->
                                <StackPanel IsVisible="{Binding Plan.HasStrengths}" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Signal}"/>
                                        <TextBlock Text="{l:T improve.strengths}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Plan.Strengths}">
                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                <TextBlock Grid.Column="0" Text="✓" FontWeight="Bold" Foreground="{DynamicResource Signal}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Lacunas a fechar -->
                                <StackPanel IsVisible="{Binding Plan.HasSkillGaps}" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Amber}"/>
                                        <TextBlock Text="{l:T improve.gaps}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Plan.SkillGaps}">
                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:SkillGap">
                                            <Border Background="{DynamicResource Panel2}" CornerRadius="8" Padding="11,8" Margin="0,3,0,0">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding Done, Mode=TwoWay}" VerticalAlignment="Top" MinWidth="0" Margin="0,-2,6,0" ToolTip.Tip="{l:T improve.done.tip}"/>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="{Binding Skill}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                                        <TextBlock Text="{Binding Why}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" IsVisible="{Binding HasWhy}"/>
                                                        <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding HasAction}" Margin="0,1,0,0">
                                                            <TextBlock Grid.Column="0" Text="→" Foreground="{DynamicResource AccentText}" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Top"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Action}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource TextSoft}"/>
                                                        </Grid>
                                                        <!-- Corpus grounding: is this gap seen in the user's own jobs? (poisoning-aware, honest) -->
                                                        <Border CornerRadius="6" Padding="7,1" Margin="0,3,0,0" HorizontalAlignment="Left" Background="{DynamicResource Signal}" IsVisible="{Binding HasCorpusHits}">
                                                            <TextBlock Text="{Binding CorpusLabel}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                        <TextBlock Text="{l:T improve.gap.webonly}" FontSize="10.5" FontStyle="Italic" Foreground="{DynamicResource Muted}" Margin="0,3,0,0" IsVisible="{Binding !HasCorpusHits}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Papéis-alvo -->
                                <StackPanel IsVisible="{Binding Plan.HasTargetRoles}" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}"/>
                                        <TextBlock Text="{l:T improve.roles}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Plan.TargetRoles}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                            <Border Classes="chip" Padding="10,5" Margin="0,4,7,0">
                                                <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold"/>
                                            </Border></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Trajetória salarial -->
                        <Border IsVisible="{Binding Plan.HasSalary}" Classes="card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Signal}"/>
                                    <TextBlock Text="{l:T improve.salaryTraj}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                </StackPanel>
                                <Grid ColumnDefinitions="*,12,*">
                                    <Border Grid.Column="0" Background="{DynamicResource Panel2}" CornerRadius="8" Padding="12" IsVisible="{Binding Plan.HasSalaryNow}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{l:T improve.now}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                            <TextBlock Text="{Binding Plan.SalaryNow}" FontSize="16" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="8" Padding="12" IsVisible="{Binding Plan.HasSalaryPotential}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{l:T improve.potential}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource AccentText}"/>
                                            <TextBlock Text="{Binding Plan.SalaryPotential}" FontSize="16" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding Plan.SalaryRationale}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" IsVisible="{Binding Plan.HasSalaryRationale}"/>
                            </StackPanel>
                        </Border>

                        <!-- Próximos passos -->
                        <Border IsVisible="{Binding Plan.HasSteps}" Classes="card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}"/>
                                    <TextBlock Text="{l:T improve.steps}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Plan.Steps}">
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:PlanStep">
                                        <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,4,0,0">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Done, Mode=TwoWay}" VerticalAlignment="Top" MinWidth="0" Margin="0,-2,6,0" ToolTip.Tip="{l:T improve.done.tip}"/>
                                            <Border Grid.Column="1" Background="{DynamicResource AccentSoft}" CornerRadius="7" Padding="8,3" Margin="0,1,11,0" VerticalAlignment="Top" IsVisible="{Binding HasHorizon}">
                                                <TextBlock Text="{Binding Horizon}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource AccentText}" FontFamily="{DynamicResource MonoFont}"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" Spacing="1">
                                                <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                <TextBlock Text="{Binding Detail}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" IsVisible="{Binding HasDetail}"/>
                                            </StackPanel>
                                        </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Sinais do mercado + bottom line + fontes -->
                        <Border Classes="card">
                            <StackPanel Spacing="9">
                                <StackPanel IsVisible="{Binding Plan.HasMarketSignals}" Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Muted}"/>
                                        <TextBlock Text="{l:T improve.signals}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Plan.MarketSignals}">
                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String">
                                            <Grid ColumnDefinitions="18,*" Margin="0,2,0,0">
                                                <TextBlock Grid.Column="0" Text="○" Foreground="{DynamicResource Muted}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"/>
                                            </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <TextBlock Text="{Binding Plan.BottomLine}" FontSize="12.5" FontStyle="Italic" Opacity="0.92" TextWrapping="Wrap" Foreground="{DynamicResource Text}" IsVisible="{Binding Plan.HasBottomLine}"/>

                                <StackPanel IsVisible="{Binding Plan.HasSources}" Spacing="1" Margin="0,2,0,0">
                                    <TextBlock Text="FONTES" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"/>
                                    <ItemsControl ItemsSource="{Binding Plan.Sources}">
                                        <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:SourceRef">
                                            <Button Classes="link" Content="{Binding Label}" FontSize="11"
                                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenUrlCommand}" CommandParameter="{Binding Url}"/>
                                        </DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <md:MarkdownScrollViewer Markdown="{Binding Plan.RawFallback}" MaxHeight="440" MarkdownStyleName="FluentAvalonia" IsVisible="{Binding Plan.HasFallback}"/>
                            </StackPanel>
                        </Border>

                        <!-- Skills radar (Part C): your stack vs. your matched market's demand -->
                        <Border IsVisible="{Binding HasRadar}" Classes="card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Accent}"/>
                                    <TextBlock Text="{l:T improve.radar.title}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource AccentText}"/>
                                </StackPanel>
                                <ctl:SkillsRadar ItemsSource="{Binding RadarAxes}" Height="248" HorizontalAlignment="Stretch"
                                                 DemandBrush="{DynamicResource Accent}" YouBrush="{DynamicResource Signal}"
                                                 GridBrush="{DynamicResource Muted}" LabelBrush="{DynamicResource Muted}"/>
                                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Width="11" Height="11" CornerRadius="2" Background="{DynamicResource Accent}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{l:T improve.radar.demand}" FontSize="11" Foreground="{DynamicResource Muted}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Width="11" Height="11" CornerRadius="2" Background="{DynamicResource Signal}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{l:T improve.radar.you}" FontSize="11" Foreground="{DynamicResource Muted}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Revisão crítica: the plan red-teamed by an adversarial pass -->
                        <Border IsVisible="{Binding HasPlanCritique}" Classes="card" BorderBrush="{DynamicResource Danger}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="3" Height="15" CornerRadius="2" Background="{DynamicResource Danger}"/>
                                    <TextBlock Text="{l:T improve.critique}" FontSize="11" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" Foreground="{DynamicResource Danger}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding PlanCritique}">
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:CritiquePoint">
                                        <Grid ColumnDefinitions="16,*" Margin="0,4,0,0">
                                            <TextBlock Grid.Column="0" Text="⚠" FontSize="12" Foreground="{DynamicResource Danger}" VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Text="{Binding Claim}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                <TextBlock Text="{Binding Issue}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Muted}"/>
                                                <Grid ColumnDefinitions="Auto,*" Margin="0,2,0,0" IsVisible="{Binding HasRebuttal}">
                                                    <TextBlock Grid.Column="0" Text="{l:T improve.rebuttal}" FontSize="10.5" FontWeight="Bold" Margin="0,0,6,0" Foreground="{DynamicResource AccentText}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Rebuttal}" FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Model reasoning — the full generation transcript. Collapsed by default; never in the PDF. -->
                        <Expander IsVisible="{Binding HasPlanReasoning}" Header="{l:T plan.reasoning.title}">
                            <StackPanel Spacing="7" Margin="2,4,2,2">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Grid.Column="0" Classes="sub" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" Text="{l:T plan.reasoning.hint}"/>
                                    <Button Grid.Column="1" Classes="ghost" Margin="8,0,0,0" Command="{Binding CopyReasoningCommand}">
                                        <Panel>
                                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding !ReasoningCopied}"><ui:SymbolIcon Symbol="Copy"/><TextBlock Text="{l:T reasoning.copy}"/></StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding ReasoningCopied}"><ui:SymbolIcon Symbol="Checkmark" FontSize="14" Foreground="{DynamicResource Signal}" VerticalAlignment="Center"/><TextBlock Text="{l:T reasoning.copied}"/></StackPanel>
                                        </Panel>
                                    </Button>
                                    <Button Grid.Column="2" Classes="ghost" Margin="6,0,0,0" Command="{Binding SaveReasoningCommand}" IsEnabled="{Binding !Busy}">
                                        <StackPanel Orientation="Horizontal" Spacing="6"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T reasoning.save}"/></StackPanel>
                                    </Button>
                                </Grid>
                                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding PlanReasoning}" FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                               TextWrapping="Wrap" Foreground="{DynamicResource Muted}"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Expander>

                        <!-- Histórico de planos: cada regeneração arquiva o anterior aqui -->
                        <Expander IsVisible="{Binding HasPlanHistory}" Header="{l:T improve.history}">
                            <StackPanel Spacing="8" Margin="2,4,2,2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="sub" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" Text="{l:T improve.history.hint}"/>
                                    <Button Grid.Column="1" Classes="ghost" Margin="8,0,0,0" Command="{Binding ClearPlanHistoryCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6"><ui:SymbolIcon Symbol="Delete"/><TextBlock Text="{l:T improve.history.clear}"/></StackPanel>
                                    </Button>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PlanHistory}">
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:PlanSnapshot">
                                        <Border Background="{DynamicResource Panel2}" CornerRadius="8" Padding="11,8" Margin="0,3,0,0">
                                            <StackPanel Spacing="2">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding AsOfDate}" FontSize="11" FontWeight="Bold" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource AccentText}"/>
                                                    <Border Grid.Column="1" Background="{DynamicResource AccentSoft}" CornerRadius="6" Padding="7,1" IsVisible="{Binding HasProgress}">
                                                        <TextBlock Text="{Binding ProgressText}" FontSize="10.5" FontWeight="SemiBold" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource AccentText}"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Headline}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                                <TextBlock Text="{Binding SalaryLine}" FontSize="11" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource Muted}" IsVisible="{Binding HasSalaryLine}"/>
                                            </StackPanel>
                                        </Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </StackPanel>

                <!-- ============ COACH ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsCoach}" Spacing="10">
                    <TextBlock Classes="h1" Text="{l:T coach.title}"/>
                    <TextBlock Classes="sub" Text="{l:T coach.sub}" TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="Auto,8,260,*,Auto" Margin="0,2,0,0">
                        <TextBlock Grid.Column="0" FontSize="10" FontWeight="Bold" LetterSpacing="1" Foreground="{DynamicResource Muted}"
                                   VerticalAlignment="Center" Text="{l:T coach.company}"/>
                        <ComboBox Grid.Column="2" HorizontalAlignment="Stretch" IsEnabled="{Binding !IsCoachSending}"
                                  ItemsSource="{Binding CoachCompanyOptions}" SelectedIndex="{Binding CoachCompanyIndex}"/>
                        <Button Grid.Column="4" Classes="ghost" Command="{Binding ClearCoachCommand}" IsVisible="{Binding !CoachEmpty}">
                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Delete"/><TextBlock Text="{l:T coach.clear}"/></StackPanel>
                        </Button>
                    </Grid>

                    <ctl:EmptyState Symbol="Comment" IsVisible="{Binding CoachEmpty}"
                                    Title="{l:T coach.empty.title}" Body="{l:T coach.empty.body}"/>

                    <ScrollViewer x:Name="CoachScroll" MaxHeight="460" VerticalScrollBarVisibility="Auto" IsVisible="{Binding !CoachEmpty}">
                        <ItemsControl ItemsSource="{Binding CoachTranscript}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CoachMessageVm">
                                    <Border Classes="bubble" Classes.user="{Binding IsUser}">
                                        <StackPanel Spacing="6">
                                            <ItemsControl ItemsSource="{Binding Thumbs}" IsVisible="{Binding HasThumbs}">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate><DataTemplate>
                                                    <Border CornerRadius="6" ClipToBounds="True" Margin="0,0,6,6">
                                                        <Image Source="{Binding}" MaxWidth="220" Stretch="Uniform"/>
                                                    </Border>
                                                </DataTemplate></ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- plain text for user msgs AND while streaming; markdown once complete -->
                                            <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"
                                                                 IsVisible="{Binding !ShowFinalMarkdown}"/>
                                            <md:MarkdownScrollViewer Markdown="{Binding Text}" MarkdownStyleName="FluentAvalonia"
                                                                     IsVisible="{Binding ShowFinalMarkdown}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowSpinner}">
                                                <ui:ProgressRing IsIndeterminate="True" Width="15" Height="15"/>
                                                <TextBlock Classes="sub" Text="{l:T coach.thinking}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Classes="banner danger" IsVisible="{Binding CoachError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <ui:SymbolIcon Symbol="Important" Foreground="{DynamicResource Danger}" VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding CoachError}" FontSize="12" TextWrapping="Wrap" MaxWidth="640"
                                       Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="chip" HorizontalAlignment="Left"
                            IsVisible="{Binding CoachVisionWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:SymbolIcon Symbol="Important" FontSize="13" Foreground="{DynamicResource Amber}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CoachVisionWarning}" FontSize="11.5" TextWrapping="Wrap" MaxWidth="560"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding CoachAttachments}" IsVisible="{Binding HasCoachAttachments}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CoachAttachmentVm">
                                <Border Classes="chip" Margin="0,0,8,6" Padding="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Image Source="{Binding Thumb}" Height="40" Stretch="Uniform"/>
                                        <Button Classes="link" VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).RemoveCoachAttachmentCommand}"
                                                CommandParameter="{Binding}">
                                            <ui:SymbolIcon Symbol="Dismiss" FontSize="13"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid ColumnDefinitions="*,8,Auto,Auto" Margin="0,4,0,0">
                        <TextBox x:Name="CoachInputBox" Grid.Column="0" Text="{Binding CoachInput}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="44" MaxHeight="140"
                                 Watermark="{l:T coach.input.wm}" IsEnabled="{Binding !IsCoachSending}"/>
                        <Button Grid.Column="2" Classes="ghost" Click="OnCoachAttach" VerticalAlignment="Bottom"
                                IsEnabled="{Binding !IsCoachSending}" ToolTip.Tip="{l:T coach.attach.tip}">
                            <ui:SymbolIcon Symbol="Attach"/>
                        </Button>
                        <Panel Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Bottom">
                            <Button Classes="accent" Command="{Binding SendCoachCommand}" IsVisible="{Binding !IsCoachSending}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Send"/><TextBlock Text="{l:T coach.send}"/></StackPanel>
                            </Button>
                            <Button Classes="ghost" Command="{Binding StopCoachCommand}" IsVisible="{Binding IsCoachSending}">
                                <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Stop"/><TextBlock Text="{l:T coach.stop}"/></StackPanel>
                            </Button>
                        </Panel>
                    </Grid>
                </StackPanel>

                <!-- ============ CV STUDIO ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsCv}" Spacing="10">
                    <TextBlock Classes="h1" Text="{l:T cv.title}"/>
                    <TextBlock Classes="sub" Text="{l:T cv.sub}" TextWrapping="Wrap"/>

                    <!-- empty state: import PDF or seed from profile -->
                    <StackPanel Spacing="10" IsVisible="{Binding !HasCvDoc}">
                        <ctl:EmptyState Symbol="Document" Title="{l:T cv.empty.title}" Body="{l:T cv.empty.body}">
                            <ctl:EmptyState.ActionContent>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Button Classes="accent" Click="OnPickCvForStudio" ToolTip.Tip="{l:T cv.import.tip}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="OpenFile"/><TextBlock Text="{l:T cv.import}"/></StackPanel>
                                    </Button>
                                    <Button Classes="ghost" Command="{Binding SeedCvFromProfileCommand}" IsEnabled="{Binding HasSavedProfile}" ToolTip.Tip="{l:T cv.seed.tip}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Contact"/><TextBlock Text="{l:T cv.seed}"/></StackPanel>
                                    </Button>
                                </StackPanel>
                            </ctl:EmptyState.ActionContent>
                        </ctl:EmptyState>
                        <StackPanel Orientation="Horizontal" Spacing="9" IsVisible="{Binding Busy}" HorizontalAlignment="Center">
                            <ui:ProgressRing IsIndeterminate="True" Width="15" Height="15" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CvStatus}" FontSize="12" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource AccentText}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CvStatus}" FontSize="12" Foreground="{DynamicResource Danger}" TextWrapping="Wrap" HorizontalAlignment="Center" IsVisible="{Binding !Busy}"/>
                    </StackPanel>

                    <!-- editor -->
                    <StackPanel Spacing="10" IsVisible="{Binding HasCvDoc}">
                        <!-- toolbar -->
                        <Border Classes="card" Padding="14">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,8,*,16,Auto,8,*,16,Auto,8,*">
                                    <TextBlock Grid.Column="0" Classes="fld" VerticalAlignment="Center" Text="{l:T cv.template}"/>
                                    <ComboBox Grid.Column="2" HorizontalAlignment="Stretch" ItemsSource="{Binding CvTemplateOptions}" SelectedIndex="{Binding CvTemplateIndex}"/>
                                    <TextBlock Grid.Column="4" Classes="fld" VerticalAlignment="Center" Text="{l:T cv.lang}"/>
                                    <ComboBox Grid.Column="6" HorizontalAlignment="Stretch" ItemsSource="{Binding CvLangOptions}" SelectedIndex="{Binding CvLangIndex}"/>
                                    <TextBlock Grid.Column="8" Classes="fld" VerticalAlignment="Center" Text="{l:T cv.accent}"/>
                                    <ComboBox Grid.Column="10" HorizontalAlignment="Stretch" ItemsSource="{Binding CvAccentOptions}" SelectedIndex="{Binding CvAccentIndex}"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="ghost" Command="{Binding SaveCvCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T cv.save}"/></StackPanel>
                                    </Button>
                                    <Button Classes="ghost" Command="{Binding PreviewCvCommand}" ToolTip.Tip="{l:T cv.preview.tip}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Open"/><TextBlock Text="{l:T cv.preview}"/></StackPanel>
                                    </Button>
                                    <Button Classes="accent" Command="{Binding ExportCvPdfCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Download"/><TextBlock Text="{l:T cv.export}"/></StackPanel>
                                    </Button>
                                    <Button Classes="link" Click="OnPickCvForStudio" Content="{l:T cv.import}" VerticalAlignment="Center" ToolTip.Tip="{l:T cv.import.tip}"/>
                                    <Border Classes="chip" VerticalAlignment="Center" IsVisible="{Binding HasCvTailored}">
                                        <TextBlock Text="{Binding CvTailoredChip}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding CvStatus}" FontSize="11.5" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"
                                           IsVisible="{Binding CvStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Border>

                        <!-- header -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="h2" Text="{l:T cv.sec.header}"/>
                                <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,0,6">
                                        <TextBlock Classes="fld" Text="{l:T cv.name}"/><TextBox Text="{Binding CvFullName}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="2" Margin="0,0,0,6">
                                        <TextBlock Classes="fld" Text="{l:T cv.headline}"/><TextBox Text="{Binding CvHeadline}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,0,6">
                                        <TextBlock Classes="fld" Text="{l:T cv.email}"/><TextBox Text="{Binding CvEmail}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2" Margin="0,0,0,6">
                                        <TextBlock Classes="fld" Text="{l:T cv.phone}"/><TextBox Text="{Binding CvPhone}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2" Margin="0,0,0,6">
                                        <TextBlock Classes="fld" Text="{l:T cv.location}"/><TextBox Text="{Binding CvLocation}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Grid.RowSpan="2" Spacing="2">
                                        <TextBlock Classes="fld" Text="{l:T cv.links}"/>
                                        <TextBox Text="{Binding CvLinksText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56" Watermark="{l:T cv.links.wm}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- summary -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="h2" Text="{l:T cv.sec.summary}"/>
                                <TextBox Text="{Binding CvSummary}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64"/>
                            </StackPanel>
                        </Border>

                        <!-- experience -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="{l:T cv.sec.experience}"/>
                                <ItemsControl x:Name="CvExpList" ItemsSource="{Binding CvExperience}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CvExperienceVm">
                                            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,10,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <Grid ColumnDefinitions="*,8,*">
                                                            <StackPanel Grid.Column="0" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.company}"/><TextBox Text="{Binding Company}"/></StackPanel>
                                                            <StackPanel Grid.Column="2" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.role}"/><TextBox Text="{Binding Role}"/></StackPanel>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="*,8,*,8,*">
                                                            <StackPanel Grid.Column="0" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.start}"/><TextBox Text="{Binding Start}"/></StackPanel>
                                                            <StackPanel Grid.Column="2" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.end}"/><TextBox Text="{Binding End}"/></StackPanel>
                                                            <StackPanel Grid.Column="4" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.location}"/><TextBox Text="{Binding Location}"/></StackPanel>
                                                        </Grid>
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Classes="fld" Text="{l:T cv.exp.bullets}"/>
                                                            <TextBox Text="{Binding BulletsText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="70" Watermark="{l:T cv.exp.bullets.wm}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="4">
                                                        <Button Classes="ghost" Content="↑" Command="{Binding ((vm:MainViewModel)DataContext).MoveCvExperienceUpCommand, ElementName=CvExpList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.up}"/>
                                                        <Button Classes="ghost" Content="↓" Command="{Binding ((vm:MainViewModel)DataContext).MoveCvExperienceDownCommand, ElementName=CvExpList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.down}"/>
                                                        <Button Classes="ghost" Command="{Binding ((vm:MainViewModel)DataContext).RemoveCvExperienceCommand, ElementName=CvExpList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.remove}">
                                                            <ui:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="ghost" Command="{Binding AddCvExperienceCommand}" Content="{l:T cv.exp.add}"/>
                            </StackPanel>
                        </Border>

                        <!-- education -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="{l:T cv.sec.education}"/>
                                <ItemsControl x:Name="CvEduList" ItemsSource="{Binding CvEducation}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CvEducationVm">
                                            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,10,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <Grid ColumnDefinitions="*,8,*">
                                                            <StackPanel Grid.Column="0" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.edu.school}"/><TextBox Text="{Binding School}"/></StackPanel>
                                                            <StackPanel Grid.Column="2" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.edu.degree}"/><TextBox Text="{Binding Degree}"/></StackPanel>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="*,8,*,8,*">
                                                            <StackPanel Grid.Column="0" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.start}"/><TextBox Text="{Binding Start}"/></StackPanel>
                                                            <StackPanel Grid.Column="2" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.end}"/><TextBox Text="{Binding End}"/></StackPanel>
                                                            <StackPanel Grid.Column="4" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.exp.location}"/><TextBox Text="{Binding Location}"/></StackPanel>
                                                        </Grid>
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Classes="fld" Text="{l:T cv.edu.details}"/>
                                                            <TextBox Text="{Binding DetailsText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="4">
                                                        <Button Classes="ghost" Content="↑" Command="{Binding ((vm:MainViewModel)DataContext).MoveCvEducationUpCommand, ElementName=CvEduList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.up}"/>
                                                        <Button Classes="ghost" Content="↓" Command="{Binding ((vm:MainViewModel)DataContext).MoveCvEducationDownCommand, ElementName=CvEduList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.down}"/>
                                                        <Button Classes="ghost" Command="{Binding ((vm:MainViewModel)DataContext).RemoveCvEducationCommand, ElementName=CvEduList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.remove}">
                                                            <ui:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="ghost" Command="{Binding AddCvEducationCommand}" Content="{l:T cv.edu.add}"/>
                            </StackPanel>
                        </Border>

                        <!-- projects -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="h2" Text="{l:T cv.sec.projects}"/>
                                <ItemsControl x:Name="CvProjList" ItemsSource="{Binding CvProjects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CvProjectVm">
                                            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,10,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <Grid ColumnDefinitions="*,8,*">
                                                            <StackPanel Grid.Column="0" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.proj.name}"/><TextBox Text="{Binding Name}"/></StackPanel>
                                                            <StackPanel Grid.Column="2" Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.proj.link}"/><TextBox Text="{Binding Link}"/></StackPanel>
                                                        </Grid>
                                                        <StackPanel Spacing="2"><TextBlock Classes="fld" Text="{l:T cv.proj.desc}"/><TextBox Text="{Binding Description}"/></StackPanel>
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Classes="fld" Text="{l:T cv.exp.bullets}"/>
                                                            <TextBox Text="{Binding BulletsText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="4">
                                                        <Button Classes="ghost" Content="↑" Command="{Binding ((vm:MainViewModel)DataContext).MoveCvProjectUpCommand, ElementName=CvProjList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.up}"/>
                                                        <Button Classes="ghost" Content="↓" Command="{Binding ((vm:MainViewModel)DataContext).MoveCvProjectDownCommand, ElementName=CvProjList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.down}"/>
                                                        <Button Classes="ghost" Command="{Binding ((vm:MainViewModel)DataContext).RemoveCvProjectCommand, ElementName=CvProjList}" CommandParameter="{Binding}" ToolTip.Tip="{l:T cv.row.remove}">
                                                            <ui:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="ghost" Command="{Binding AddCvProjectCommand}" Content="{l:T cv.proj.add}"/>
                            </StackPanel>
                        </Border>

                        <!-- skills / certs / languages -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="h2" Text="{l:T cv.sec.skills}"/>
                                <TextBlock Classes="fld" Text="{l:T cv.skills.groups}"/>
                                <TextBox Text="{Binding CvSkillGroupsText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56" Watermark="{l:T cv.skills.wm}"/>
                                <TextBlock Classes="fld" Text="{l:T cv.certs}" Margin="0,6,0,0"/>
                                <TextBox Text="{Binding CvCertsText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48"/>
                                <TextBlock Classes="fld" Text="{l:T cv.langs}" Margin="0,6,0,0"/>
                                <TextBox Text="{Binding CvLanguagesText}"/>
                            </StackPanel>
                        </Border>

                        <!-- CV assistant: critiques AND applies edits, with undo -->
                        <Border Classes="card" Padding="16">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Classes="h2" Text="{l:T cv.sec.chat}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="link" Command="{Binding ClearCvChatCommand}" Content="{l:T coach.clear}" IsVisible="{Binding !CvChatEmpty}"/>
                                </Grid>

                                <Border Classes="chip" HorizontalAlignment="Left"
                                        IsVisible="{Binding CvChangeNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ui:SymbolIcon Symbol="Checkmark" FontSize="13" Foreground="{DynamicResource Signal}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CvChangeNote}" FontSize="11.5" TextWrapping="Wrap" MaxWidth="520" VerticalAlignment="Center"/>
                                        <Button Classes="link" Command="{Binding UndoCvChangeCommand}" Content="{l:T cv.chat.undo}" IsEnabled="{Binding CanUndoCv}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <ctl:EmptyState Symbol="Comment" IsVisible="{Binding CvChatEmpty}"
                                                Title="{l:T cv.chat.empty.title}" Body="{l:T cv.chat.empty.body}"/>

                                <ScrollViewer x:Name="CvChatScroll" MaxHeight="420" VerticalScrollBarVisibility="Auto" IsVisible="{Binding !CvChatEmpty}">
                                    <ItemsControl ItemsSource="{Binding CvChatTranscript}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:CoachMessageVm">
                                                <Border Classes="bubble" Classes.user="{Binding IsUser}">
                                                    <StackPanel Spacing="6">
                                                        <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{DynamicResource Text}"
                                                                             IsVisible="{Binding !ShowFinalMarkdown}"/>
                                                        <md:MarkdownScrollViewer Markdown="{Binding Text}" MarkdownStyleName="FluentAvalonia"
                                                                                 IsVisible="{Binding ShowFinalMarkdown}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ShowSpinner}">
                                                            <ui:ProgressRing IsIndeterminate="True" Width="15" Height="15"/>
                                                            <TextBlock Classes="sub" Text="{l:T coach.thinking}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Classes="banner danger" IsVisible="{Binding CvChatError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <StackPanel Orientation="Horizontal" Spacing="9">
                                        <ui:SymbolIcon Symbol="Important" Foreground="{DynamicResource Danger}" VerticalAlignment="Top"/>
                                        <TextBlock Text="{Binding CvChatError}" FontSize="12" TextWrapping="Wrap" MaxWidth="640"
                                                   Foreground="{DynamicResource Text}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,8,Auto">
                                    <TextBox x:Name="CvChatInputBox" Grid.Column="0" Text="{Binding CvChatInput}"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="44" MaxHeight="140"
                                             Watermark="{l:T cv.chat.input.wm}" IsEnabled="{Binding !IsCvChatSending}"/>
                                    <Panel Grid.Column="2" VerticalAlignment="Bottom">
                                        <Button Classes="accent" Command="{Binding SendCvChatCommand}" IsVisible="{Binding !IsCvChatSending}">
                                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Send"/><TextBlock Text="{l:T coach.send}"/></StackPanel>
                                        </Button>
                                        <Button Classes="ghost" Command="{Binding StopCvChatCommand}" IsVisible="{Binding IsCvChatSending}">
                                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Stop"/><TextBlock Text="{l:T coach.stop}"/></StackPanel>
                                        </Button>
                                    </Panel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- ============ SETTINGS ============ -->
                <StackPanel Classes="page" IsVisible="{Binding IsSettings}" Spacing="6" MaxWidth="660">
                    <TextBlock Classes="h1" Text="{l:T nav.settings}"/>
                    <TextBlock Classes="sub" Text="{l:T settings.sub}"/>

                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="fld" Text="{l:T settings.language}" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedIndex="{Binding LanguageIndex}" Width="160"/>
                                <TextBlock Classes="sub" VerticalAlignment="Center" Text="{l:T settings.language.hint}"/>
                            </StackPanel>
                            <TextBlock Classes="fld" Text="{l:T settings.appearance}" Margin="0,8,0,2"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedIndex="{Binding ThemeIndex}" Width="160"/>
                                <TextBlock Classes="sub" VerticalAlignment="Center" Text="{l:T settings.appearance.hint}"/>
                            </StackPanel>
                            <TextBlock Classes="fld" Text="{l:T settings.textsize}" Margin="0,8,0,2"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <ComboBox ItemsSource="{Binding TextSizeOptions}" SelectedIndex="{Binding TextSizeIndex}" Width="160"/>
                                <TextBlock Text="{Binding ZoomLabel}" VerticalAlignment="Center"
                                           FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource Muted}"/>
                            </StackPanel>
                            <TextBlock Classes="sub" Text="{l:T settings.textsize.hint}"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="fld" Text="{l:T settings.aiEngine}" Margin="0,0,0,2"/>
                            <ToggleSwitch IsChecked="{Binding UseLocalModel}" OnContent="{l:T settings.localModel}" OffContent="Claude CLI"/>
                            <TextBlock Classes="sub" TextWrapping="Wrap"
                                       Text="{l:T settings.aiEngine.hint}"/>

                            <!-- ===== Local model manager (Ollama) ===== -->
                            <StackPanel IsVisible="{Binding UseLocalModel}" Spacing="8">
                                <!-- machine-aware recommended first model -->
                                <Border Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                                    <StackPanel Spacing="7">
                                        <TextBlock Text="{Binding RecommendedLabel}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" Foreground="{DynamicResource Text}"/>
                                        <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T models.recommend.why}" IsVisible="{Binding !RecommendedInstalled}"/>
                                        <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource Signal}" Text="{l:T models.recommend.have}" IsVisible="{Binding RecommendedInstalled}"/>
                                        <Button Classes="accent" HorizontalAlignment="Left" Command="{Binding InstallRecommendedCommand}" IsEnabled="{Binding !IsPullingModel}" IsVisible="{Binding !RecommendedInstalled}">
                                            <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Download"/><TextBlock Text="{l:T models.install}"/></StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" Text="{l:T models.smallWarn}"/>

                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="fld" Text="{l:T models.section}" Margin="0,4,0,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="link" Command="{Binding RefreshInstalledModelsCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="5"><ui:SymbolIcon Symbol="Refresh" FontSize="13"/><TextBlock Text="{l:T models.refresh}"/></StackPanel>
                                    </Button>
                                </Grid>

                                <!-- installed models -->
                                <ItemsControl ItemsSource="{Binding InstalledModels}" IsVisible="{Binding HasInstalledModels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:OllamaModelVm">
                                            <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" Padding="12,9" Margin="0,0,0,6">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                    <Button Grid.Column="0" Classes="link" HorizontalAlignment="Left" Padding="0" HorizontalContentAlignment="Left"
                                                            Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).SetActiveModelCommand}" CommandParameter="{Binding}"
                                                            ToolTip.Tip="{l:T models.setActive.tip}">
                                                        <StackPanel Spacing="1">
                                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13.5" Foreground="{DynamicResource Text}"/>
                                                                <Border Background="{DynamicResource AccentSoft}" CornerRadius="6" Padding="6,1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding SourceLabel}" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource AccentText}"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Meta}" FontSize="11" Foreground="{DynamicResource Muted}" FontFamily="{DynamicResource MonoFont}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Border Grid.Column="1" Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="8,3" VerticalAlignment="Center" Margin="6,0,8,0" IsVisible="{Binding IsActive}">
                                                        <TextBlock Text="{l:T models.active}" Foreground="{DynamicResource Signal}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <Button Grid.Column="2" Classes="ghost" Padding="10,7" VerticalAlignment="Center" ToolTip.Tip="{l:T models.remove.tip}"
                                                            Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).RemoveModelCommand}" CommandParameter="{Binding}">
                                                        <ui:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- empty / unreachable -->
                                <TextBlock Classes="sub" FontSize="12" TextWrapping="Wrap" IsVisible="{Binding !HasInstalledModels}" Text="{l:T models.none}"/>
                                <StackPanel Spacing="9" IsVisible="{Binding ShowOllamaWarning}">
                                    <TextBlock Classes="sub" FontSize="12" TextWrapping="Wrap" Text="{l:T models.unreachable}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Classes="accent" Content="{l:T models.installOllama}" Command="{Binding InstallOllamaCommand}" IsEnabled="{Binding !IsInstallingOllama}"/>
                                        <Button Classes="link" Content="{l:T models.getOllama}" Command="{Binding OpenUrlCommand}" CommandParameter="https://ollama.com/download"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Ollama runtime install progress -->
                                <StackPanel Spacing="6" Margin="0,2,0,0" IsVisible="{Binding IsInstallingOllama}">
                                    <TextBlock Text="{Binding OllamaInstallStatus}" Classes="sub" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource AccentText}"/>
                                    <ProgressBar Minimum="0" Maximum="1" Value="{Binding OllamaInstallProgress}" Height="6"/>
                                </StackPanel>

                                <!-- live model browser: discover & one-click install from Ollama -->
                                <TextBlock Classes="fld" Text="{l:T models.install}" Margin="0,4,0,0"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ModelSearchText}" Watermark="{l:T models.browse}">
                                        <TextBox.InnerLeftContent><ui:SymbolIcon Symbol="Find" Margin="8,0,0,0" Foreground="{DynamicResource Muted}"/></TextBox.InnerLeftContent>
                                    </TextBox>
                                    <ui:ProgressRing Grid.Column="1" Width="18" Height="18" Margin="8,0,0,0" IsIndeterminate="True"
                                                     VerticalAlignment="Center" IsVisible="{Binding IsSearchingRegistry}"/>
                                </Grid>
                                <TextBlock Classes="sub" FontSize="11" Text="{Binding RegistrySearchStatus}"
                                           IsVisible="{Binding RegistrySearchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <ScrollViewer MaxHeight="360" IsVisible="{Binding HasRegistryResults}" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding RegistryResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:RegistryModelVm">
                                                <Border Background="{DynamicResource Panel2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="9" Padding="12,9" Margin="0,0,0,6">
                                                    <StackPanel Spacing="4">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                                <Button Classes="link" Padding="0" FontWeight="Bold" FontSize="13.5" Content="{Binding Name}"
                                                                        ToolTip.Tip="{l:T models.openPage}"
                                                                        Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).OpenModelPageCommand}" CommandParameter="{Binding}"/>
                                                                <TextBlock Text="{Binding CapBadges}" VerticalAlignment="Center" IsVisible="{Binding HasCaps}"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Classes="ghost" Padding="11,5" VerticalAlignment="Top" ToolTip.Tip="{l:T models.chooseSize.tip}"
                                                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ExpandQuantsCommand}" CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal" Spacing="6"><ui:SymbolIcon Symbol="Download" FontSize="13"/><TextBlock Text="{l:T models.chooseSize}"/></StackPanel>
                                                            </Button>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Description}" FontSize="11.5" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"
                                                                   MaxLines="2" TextTrimming="CharacterEllipsis" IsVisible="{Binding HasDescription}"/>
                                                        <TextBlock Text="{Binding Meta}" FontSize="10.5" Foreground="{DynamicResource Muted}" FontFamily="{DynamicResource MonoFont}"/>
                                                        <!-- click a size/quant to install it -->
                                                        <TextBlock Text="{l:T models.pickSize}" FontSize="11" Foreground="{DynamicResource AccentText}" IsVisible="{Binding Expanded}" Margin="0,3,0,0"/>
                                                        <ItemsControl ItemsSource="{Binding Quants}" IsVisible="{Binding Expanded}">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:QuantOption">
                                                                    <Button Classes="accent" Padding="10,4" Margin="0,4,6,0" ToolTip.Tip="{l:T models.pickSize}"
                                                                            IsEnabled="{Binding $parent[Window].((vm:MainViewModel)DataContext).IsPullingModel, Converter={x:Static BoolConverters.Not}}"
                                                                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).InstallModelCommand}" CommandParameter="{Binding Payload}">
                                                                        <StackPanel Orientation="Horizontal" Spacing="5"><ui:SymbolIcon Symbol="Download" FontSize="12"/><TextBlock Text="{Binding Label}"/></StackPanel>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <!-- per-row install feedback -->
                                                        <StackPanel IsVisible="{Binding Installing}" Spacing="3" Margin="0,5,0,0">
                                                            <ProgressBar Minimum="0" Maximum="1" Value="{Binding InstallProgress}" Height="5" CornerRadius="3"
                                                                         Foreground="{DynamicResource Accent}" Background="{DynamicResource Panel}"/>
                                                            <TextBlock Text="{Binding InstallStatus}" FontSize="11" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource AccentText}" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- or install by exact name (power users) -->
                                <TextBlock Classes="sub" FontSize="11" Text="{l:T models.byName}" Margin="0,4,0,0"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ModelToPull}" Watermark="{l:T settings.downloadModel.wm}"/>
                                    <Button Grid.Column="1" Classes="accent" Margin="8,0,0,0" Command="{Binding DownloadModelCommand}" IsEnabled="{Binding !IsPullingModel}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Download"/><TextBlock Text="{l:T settings.download}"/></StackPanel>
                                    </Button>
                                </Grid>

                                <!-- shared download progress (browser + manual) -->
                                <ProgressBar Minimum="0" Maximum="1" Value="{Binding PullProgress}" Height="6" CornerRadius="3"
                                             Foreground="{DynamicResource Accent}" Background="{DynamicResource Panel2}" IsVisible="{Binding IsPullingModel}"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{Binding ModelDownloadStatus}"
                                           IsVisible="{Binding ModelDownloadStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,4,0,0">
                                    <Button Classes="link" Content="Ollama" Command="{Binding OpenUrlCommand}" CommandParameter="https://ollama.com/download"/>
                                    <Button Classes="link" Content="{l:T setup.library}" Command="{Binding OpenUrlCommand}" CommandParameter="https://ollama.com/library"/>
                                    <Button Classes="link" Content="LM Studio" Command="{Binding OpenUrlCommand}" CommandParameter="https://lmstudio.ai"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Claude executable (Claude CLI mode) -->
                            <StackPanel IsVisible="{Binding !UseLocalModel}" Spacing="4">
                                <TextBlock Classes="fld" Text="{l:T settings.claudeExe}"/>
                                <TextBox Text="{Binding ClaudeExe}" Watermark="claude"/>
                                <TextBlock Classes="fld" Text="{l:T settings.model}"/>
                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding LlmModel}"/>
                            </StackPanel>

                            <!-- Advanced (local) — Base URL / API key / manual load, kept visible -->
                            <StackPanel IsVisible="{Binding UseLocalModel}" Spacing="4">
                                <TextBlock Classes="fld" Text="{l:T settings.advanced}" Margin="0,10,0,2"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                    <TextBlock Classes="sub" VerticalAlignment="Center" Text="{l:T settings.presets}"/>
                                    <Button Classes="ghost" Content="LM Studio" Command="{Binding UseLmStudioPresetCommand}"/>
                                    <Button Classes="ghost" Content="Ollama" Command="{Binding UseOllamaPresetCommand}"/>
                                </StackPanel>
                                <TextBlock Classes="fld" Text="BASE URL"/>
                                <TextBox Text="{Binding LlmBaseUrl}" Watermark="http://localhost:1234/v1"/>
                                <TextBlock Classes="fld" Text="{l:T settings.apiKey}"/>
                                <TextBox Text="{Binding LlmApiKey}" PasswordChar="•"/>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                    <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding LlmModel}"/>
                                    <Button Grid.Column="1" Classes="ghost" Margin="8,0,0,0" Command="{Binding LoadModelsCommand}" IsEnabled="{Binding !Busy}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Refresh"/><TextBlock Text="{l:T settings.load}"/></StackPanel>
                                    </Button>
                                </Grid>
                                <Border x:Name="MaxTokensField" Classes="flash" Classes.on="{Binding HighlightMaxTokens}" CornerRadius="9" Padding="8" Margin="0,4,0,0">
                                    <StackPanel Spacing="5">
                                        <TextBlock Classes="fld" Text="{l:T settings.maxTokens}" Margin="0"/>
                                        <NumericUpDown Value="{Binding LlmMaxTokens}" Minimum="1024" Maximum="32768" Increment="1024"
                                                       FormatString="0" Width="160" HorizontalAlignment="Left"/>
                                        <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T settings.maxTokens.hint}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                            <TextBlock Classes="sub" FontSize="11" VerticalAlignment="Center" Text="{Binding MaxTokensRecLabel}"/>
                                            <Button Classes="link" FontSize="11" VerticalAlignment="Center"
                                                    Command="{Binding UseRecommendedMaxTokensCommand}" Content="{l:T settings.maxTokens.use}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <TextBlock Classes="fld" Text="{l:T settings.timeout}"/>
                                <NumericUpDown Value="{Binding LlmTimeoutSeconds}" Minimum="30" Maximum="1800" Increment="30"
                                               FormatString="0" Width="160" HorizontalAlignment="Left"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T settings.timeout.hint}"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- LinkedIn via Apify (paid connector) -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                <TextBlock Classes="fld" Text="LINKEDIN (APIFY)" Margin="0" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource Panel2}" CornerRadius="7" Padding="7,2" VerticalAlignment="Center">
                                    <TextBlock Text="{l:T connector.paid}" Foreground="{DynamicResource Amber}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <ToggleSwitch IsChecked="{Binding UseApify}" OnContent="{l:T settings.on}" OffContent="{l:T settings.off}"/>
                            <Border BorderBrush="{DynamicResource Amber}" BorderThickness="1" Background="{DynamicResource Panel2}" CornerRadius="8" Padding="11">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Amber}">
                                    <Run Text="{l:T settings.apify.warnBold}" FontWeight="Bold"/><Run Text="{l:T settings.apify.warn}"/>
                                </TextBlock>
                            </Border>
                            <StackPanel IsVisible="{Binding UseApify}" Spacing="4">
                                <TextBlock Classes="fld" Text="APIFY API TOKEN"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ApifyToken}" PasswordChar="•" Watermark="apify_api_…"/>
                                    <Button Grid.Column="1" Classes="ghost" Margin="8,0,0,0" Command="{Binding ProbeApifyCommand}" IsEnabled="{Binding !Busy}"
                                            ToolTip.Tip="{l:T settings.apify.test.tip}">
                                        <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Globe"/><TextBlock Text="{l:T settings.apify.test}"/></StackPanel>
                                    </Button>
                                </Grid>
                                <Button Classes="link" Content="{l:T connector.getKey}" HorizontalAlignment="Left"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="https://console.apify.com/settings/integrations"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{Binding ApifyStatus}"
                                           IsVisible="{Binding ApifyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Classes="fld" Text="ACTOR"/>
                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ApifyActorOptions}" SelectedItem="{Binding ApifyActor}"/>
                                <TextBlock Classes="fld" Text="{l:T settings.apify.max}"/>
                                <TextBox Text="{Binding ApifyMax}" Watermark="50"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap"
                                           Text="{l:T settings.apify.hint}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- JSearch (RapidAPI) connector -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                <TextBlock Classes="fld" Text="{l:T settings.jsearch}" Margin="0" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="7,2" VerticalAlignment="Center">
                                    <TextBlock Text="{l:T connector.free}" Foreground="{DynamicResource Signal}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <ToggleSwitch IsChecked="{Binding UseJSearch}" OnContent="{l:T settings.on}" OffContent="{l:T settings.off}"/>
                            <Border BorderBrush="{DynamicResource Amber}" BorderThickness="1" Background="{DynamicResource Panel2}" CornerRadius="8" Padding="11">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource Amber}">
                                    <Run Text="{l:T settings.apify.warnBold}" FontWeight="Bold"/><Run Text="{l:T settings.jsearch.warn}"/>
                                </TextBlock>
                            </Border>
                            <StackPanel IsVisible="{Binding UseJSearch}" Spacing="4">
                                <TextBlock Classes="fld" Text="{l:T settings.jsearch.provider}"/>
                                <ComboBox ItemsSource="{Binding JSearchProviders}" SelectedIndex="{Binding JSearchProviderIndex}" HorizontalAlignment="Left" MinWidth="200"/>
                                <TextBlock Classes="fld" Text="{l:T settings.jsearch.key}" Margin="0,4,0,0"/>
                                <TextBox Text="{Binding JSearchKey}" PasswordChar="•" Watermark="API key…"/>
                                <Button Classes="link" Content="{l:T connector.getKey}" HorizontalAlignment="Left"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="{Binding JSearchKeyUrl}"/>
                                <TextBlock Classes="fld" Text="{l:T settings.jsearch.country}"/>
                                <TextBox Text="{Binding JSearchCountry}" Watermark="pt" MaxLength="2" Width="80" HorizontalAlignment="Left"/>
                                <TextBlock Classes="fld" Text="{l:T settings.jsearch.max}"/>
                                <TextBox Text="{Binding JSearchMax}" Watermark="20"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T settings.jsearch.hint}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Jobicy (keyless, free) — remote jobs -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                <TextBlock Classes="fld" Text="{l:T settings.jobicy}" Margin="0" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="7,2" VerticalAlignment="Center">
                                    <TextBlock Text="{l:T connector.keyless}" Foreground="{DynamicResource Signal}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <ToggleSwitch IsChecked="{Binding UseJobicy}" OnContent="{l:T settings.on}" OffContent="{l:T settings.off}"/>
                            <StackPanel IsVisible="{Binding UseJobicy}" Spacing="4">
                                <TextBlock Classes="fld" Text="{l:T settings.region}"/>
                                <ComboBox ItemsSource="{Binding JobicyRegions}" SelectedIndex="{Binding JobicyRegionIndex}" HorizontalAlignment="Left" MinWidth="160"/>
                                <TextBlock Classes="fld" Text="{l:T settings.max}"/>
                                <TextBox Text="{Binding JobicyMax}" Watermark="50" Width="100" HorizontalAlignment="Left"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T settings.jobicy.hint}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Himalayas (keyless, free) — remote jobs -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                <TextBlock Classes="fld" Text="{l:T settings.himalayas}" Margin="0" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource SignalSoft}" CornerRadius="7" Padding="7,2" VerticalAlignment="Center">
                                    <TextBlock Text="{l:T connector.keyless}" Foreground="{DynamicResource Signal}" FontSize="10.5" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <ToggleSwitch IsChecked="{Binding UseHimalayas}" OnContent="{l:T settings.on}" OffContent="{l:T settings.off}"/>
                            <StackPanel IsVisible="{Binding UseHimalayas}" Spacing="4">
                                <TextBlock Classes="fld" Text="{l:T settings.max}"/>
                                <TextBox Text="{Binding HimalayasMax}" Watermark="40" Width="100" HorizontalAlignment="Left"/>
                                <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T settings.himalayas.hint}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Usage & limits -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="fld" Text="{l:T usage.section}" Margin="0" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Classes="link" Command="{Binding CheckUsageCommand}" IsEnabled="{Binding !CheckingUsage}">
                                    <StackPanel Orientation="Horizontal" Spacing="5"><ui:SymbolIcon Symbol="Refresh" FontSize="13"/><TextBlock Text="{l:T usage.refresh}"/></StackPanel>
                                </Button>
                            </Grid>
                            <Grid ColumnDefinitions="96,*" Margin="0,2,0,0">
                                <TextBlock Grid.Column="0" Text="Apify" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSoft}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ApifyUsage}" FontSize="12" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" FontFamily="{DynamicResource MonoFont}"/>
                            </Grid>
                            <Grid ColumnDefinitions="96,*">
                                <TextBlock Grid.Column="0" Text="JSearch" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSoft}"/>
                                <TextBlock Grid.Column="1" Text="{Binding JSearchUsage}" FontSize="12" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="96,*">
                                <TextBlock Grid.Column="0" Text="{l:T settings.aiEngine}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextSoft}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="{Binding LlmUsage}" FontSize="12" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/>
                            </Grid>
                            <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T usage.hint}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Diagnostics / logs -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="fld" Text="{l:T settings.diagnostics}" Margin="0,0,0,2"/>
                            <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{l:T settings.diagnostics.hint}"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="ghost" Command="{Binding ExportDiagnosticsCommand}" IsEnabled="{Binding !Busy}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Save"/><TextBlock Text="{l:T settings.diagnostics.export}"/></StackPanel>
                                </Button>
                                <Button Classes="ghost" Command="{Binding OpenLogsFolderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Folder"/><TextBlock Text="{l:T settings.diagnostics.openFolder}"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- About / update -->
                    <Border Classes="card" Margin="0,12,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="fld" Text="{l:T settings.about}" Margin="0,0,0,2"/>
                            <TextBlock Classes="sub" Text="{Binding AppVersion, StringFormat='Job Radar · v{0}'}" FontFamily="{DynamicResource MonoFont}"/>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Button Classes="ghost" Command="{Binding CheckForUpdateCommand}" IsEnabled="{Binding !Busy}">
                                    <StackPanel Orientation="Horizontal" Spacing="7"><ui:SymbolIcon Symbol="Refresh"/><TextBlock Text="{l:T settings.checkUpdate}"/></StackPanel>
                                </Button>
                                <Button Classes="link" Content="{l:T update.openPage}" IsVisible="{Binding HasUpdatePage}"
                                        Command="{Binding OpenUrlCommand}" CommandParameter="{Binding UpdatePageUrl}"/>
                            </StackPanel>
                            <TextBlock Classes="sub" FontSize="11" TextWrapping="Wrap" Text="{Binding UpdateStatus}"
                                       IsVisible="{Binding UpdateStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,14,0,0">
                        <Button Classes="accent" Content="{l:T settings.save}" Command="{Binding SaveSettingsCommand}"/>
                    </StackPanel>
                    <TextBlock Classes="sub" Text="{Binding Status}" Margin="0,8,0,0"
                               IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

            </Grid>
          </Border>
        </ScrollViewer>
    </Grid>
    </LayoutTransformControl>
</Window>
