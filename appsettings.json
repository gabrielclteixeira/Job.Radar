{
  "rawJobsPath": "jobs.raw.json",
  "linkedInJobsPath": "linkedin-jobs.json",
  "dbPath": "radar.db",
  "outputDir": "output",
  "profilePath": "profile.md",

  "excludeKeywords": [],
  "seniorityExclude": [
    "intern", "internship", "estágio", "graduate", "principal", "head of",
    "engineering manager", "director", "staff engineer"
  ],

  "scoreTopN": 30,
  "scoringMode": "ai",
  "stackBonus": 30,
  "offStackPenalty": 22,

  "claude": {
    "enabled": true,
    "exe": "claude",
    "timeoutSeconds": 90
  },
  "salary": {
    "floorEur": 45000,
    "targetEur": 65000,
    "aboveTargetBoost": 15,
    "belowFloorPenalty": 20,
    "noSalaryPenalty": 3,
    "usdToEur": 0.92,
    "gbpToEur": 1.17,
    "monthsPerYear": 12
  }
}
